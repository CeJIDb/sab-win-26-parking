# Virtual environment
.venv/
.venv*/
venv/

# Python
__pycache__/
*.pyc
*.pyo
 
# Node
node_modules/

# Local npm pack artifacts
skillsmp-mcp-server-1.0.0.tgz

# Cursor MCP (may contain API keys)
.cursor/mcp.json
.cursor/mcp.json.example

# Claude Code local settings (personal hooks, sounds, overrides)
.claude/settings.local.json

# Claude Code local cache (markdown-rag index timestamp etc.)
.claude/cache/

# Playwright MCP artifacts (snapshots, screenshots)
.playwright-mcp/

# Playwright saved session (cookies, storage — never commit)
.playwright-session.json

# Environment files (never committed)
.env
.env.*

# System context (temporary Markdown exchanged between agents)
docs/_system-context/
temp_context/
