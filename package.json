{
  "name": "sab-win'26",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "npm run test:smoke",
    "test:smoke": "npm run build",
    "lint:md": "node ./scripts/check-markdown.mjs",
    "lint:md-links": "node ./scripts/check-markdown-links.mjs",
    "check:branch": "node ./scripts/check-branch-name.mjs",
    "commitlint": "commitlint --from HEAD~1 --to HEAD",
    "prepare": "husky",
    "build:css": "sass ui/scss/wireframe.scss ui/wireframe.css --no-source-map",
    "build:templates": "node ./scripts/build-templates.mjs",
    "build": "npm run build:css && npm run build:templates",
    "docs:c4-preview": "node ./scripts/build-c4-preview-html.mjs",
    "ci:check": "npm run lint:md && npm run lint:md-links && npm run build",
    "commit:atomic": "node ./scripts/atomic-commit.mjs",
    "commit:atomic:yes": "node ./scripts/atomic-commit.mjs --yes",
    "commit:atomic:sh": "bash ./scripts/atomic-commit.sh",
    "commit:atomic:sh:yes": "bash ./scripts/atomic-commit.sh --yes"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CeJIDb/sab-win-26-mine-parking.git"
  },
  "keywords": [],
