{
  "name": "sab-win'26",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "npm run test:smoke",
    "test:smoke": "npm run build",
    "format": "prettier --write \"**/*.{md,json,jsonc,yml,yaml,js,jsx,ts,tsx,css,html}\"",
    "format:check": "prettier --check \"**/*.{md,json,jsonc,yml,yaml,js,jsx,ts,tsx,css,html}\"",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "lint:md:legacy": "node ./scripts/check-markdown.mjs",
    "lint:md-links": "node ./scripts/check-markdown-links.mjs",
    "lint:file-names": "node ./scripts/check-file-names.mjs",
    "check:branch": "node ./scripts/check-branch-name.mjs",
    "check:plans": "node ./scripts/validate-plans.mjs --all",
    "check:plans:staged": "node ./scripts/validate-plans.mjs --staged",
    "commitlint": "commitlint --from HEAD~1 --to HEAD",
    "prepare": "husky",
    "build:css": "sass ui/scss/wireframe.scss ui/wireframe.css --no-source-map",
    "build:templates": "node ./scripts/build-templates.mjs",
    "build": "npm run build:css && npm run build:templates",
    "docs:rag-index": "bash ./scripts/update-rag-index.sh",
    "docs:rag-index:force": "bash ./scripts/update-rag-index.sh --force",
    "ci:check": "npm run lint:md && npm run lint:md:legacy && npm run lint:md-links && npm run lint:file-names && npm run check:plans && npm run build",
    "commit": "npm run format && npm run ci:check && npm run commit:atomic",
    "commit:atomic": "node ./scripts/atomic-commit.mjs",
    "commit:atomic:yes": "node ./scripts/atomic-commit.mjs --yes",
    "commit:atomic:dry-run": "node ./scripts/atomic-commit.mjs --dry-run",
    "commit:atomic:staged": "node ./scripts/atomic-commit.mjs --staged-only",
    "commit:atomic:sh": "bash ./scripts/atomic-commit.sh",
    "commit:atomic:sh:yes": "bash ./scripts/atomic-commit.sh --yes",
    "commit:atomic:sh:dry-run": "bash ./scripts/atomic-commit.sh --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CeJIDb/sab-win-26-mine-parking.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/CeJIDb/sab-win-26-mine-parking/issues"
  },
  "homepage": "https://github.com/CeJIDb/sab-win-26-mine-parking#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.22.1",
    "nunjucks": "^3.2.4",
    "prettier": "^3.8.3",
    "puppeteer": "^23.11.1",
    "sass": "^1.77.0"
  }
}
