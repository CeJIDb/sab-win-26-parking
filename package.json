  "license": "ISC",
  "bugs": {
    "url": "https://github.com/CeJIDb/sab-win-26-mine-parking/issues"
  },
  "homepage": "https://github.com/CeJIDb/sab-win-26-mine-parking#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "husky": "^9.1.7",
    "nunjucks": "^3.2.4",
    "sass": "^1.77.0"
  }
}
