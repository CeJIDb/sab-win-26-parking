{% extends "layouts/admin.njk" %}

{% set current_nav = 'admin-contracts' %}

{% block title %}Договоры — ЛК админа{% endblock %}
{% block header_breadcrumbs %}<a href="debts.html">Клиенты</a><span class="wf-breadcrumbs__sep">/</span><span class="wf-breadcrumbs__current">Договоры</span>{% endblock %}

{% block auxiliary_nav %}
  {% set nav_current = current_nav %}
  {% include "partials/nav-clients.njk" %}
{% endblock %}

{% block content %}
  <div class="wf-page-head">
    <button type="button" class="wf-back">Назад</button>
    <h2>Управление договорами</h2>
  </div>

<section class="wf-section">
  <h3>Реестр договоров</h3>
  <div class="wf-actions">
    <a href="contracts-create.html" class="wf-btn">Создать договор</a>
  </div>
  <form class="wf-form sessions-filters" aria-label="Фильтр реестра договоров">
    <div class="filters-row">
      <div class="wf-field">
        <label for="search-contract-admin-number">№ договора</label>
        <input id="search-contract-admin-number" type="text" placeholder="Д-045">
      </div>
      <div class="wf-field">
        <label for="search-contract-admin-client-type">Тип клиента</label>
        <select id="search-contract-admin-client-type">
          <option value="">Любой</option>
          <option value="fl">ФЛ</option>
          <option value="yl">ЮЛ</option>
        </select>
      </div>
      <div class="wf-field">
        <label for="search-contract-admin-client">Клиент</label>
        <input id="search-contract-admin-client" type="text" placeholder="ФИО или название организации">
      </div>
      <div class="wf-field">
        <label for="search-contract-admin-status">Статус договора</label>
        <select id="search-contract-admin-status">
          <option value="">Любой</option>
          <option value="active">Активен</option>
          <option value="ending-soon">Скоро истекает</option>
          <option value="finished">Завершён</option>
          <option value="overdue">Просрочка</option>
        </select>
      </div>
      <div class="filter-actions">
        <button type="submit">Применить</button>
        <button type="button">Сброс</button>
      </div>
    </div>
  </form>
  <div class="wf-table-wrap">
    <table class="wf-table">
      <thead>
        <tr>
          <th scope="col">№ договора</th>
          <th scope="col">Тип клиента</th>
          <th scope="col">Клиент</th>
          <th scope="col">Период</th>
          <th scope="col">Статус договора</th>
          <th scope="col">Задолженность</th>
          <th scope="col">ТС / ПМ</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><a href="#admin-modal-contract-view">Д-045</a></td>
          <td>ФЛ</td>
          <td><a href="#admin-modal-client-fl">Иванов Иван Иванович</a></td>
          <td>01.01.2026–31.12.2026</td>
          <td><span class="wf-badge">Активен</span></td>
          <td>Нет</td>
          <td>2 ТС, 2 ПМ</td>
        </tr>
        <tr>
          <td><a href="#admin-modal-contract-view">Д-052</a></td>
          <td>ЮЛ</td>
          <td><a href="#admin-modal-client-yl">ООО «Ромашка»</a></td>
          <td>15.02.2026–14.05.2026</td>
          <td><span class="wf-badge">Скоро истекает</span></td>
          <td>Просрочка 2 дня</td>
          <td>5 ТС, 4 ПМ</td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

{% include "partials/admin-contract-modal.njk" %}
{% include "partials/admin-client-modal.njk" %}

<section class="wf-section">
  <h3>Шаблоны договоров</h3>
  <p class="wf-muted">Типовые шаблоны договоров, которые используются при оформлении для разных типов клиентов.</p>
  <div class="wf-actions">
    <a href="#admin-modal-contract-template-new" class="wf-btn">Создать шаблон</a>
  </div>
  <div class="wf-table-wrap">
    <table class="wf-table">
      <thead>
        <tr>
          <th scope="col">Тип клиента</th>
          <th scope="col">Название шаблона</th>
          <th scope="col">Действия</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Физическое лицо</td>
          <td>Долгосрочная парковка (ФЛ)</td>
          <td>
            <a href="#admin-modal-contract-template-fl" class="wf-btn">Редактировать шаблон</a>
          </td>
        </tr>
        <tr>
          <td>Юридическое лицо</td>
          <td>Долгосрочная парковка (ЮЛ)</td>
          <td>
            <a href="#admin-modal-contract-template-yl" class="wf-btn">Редактировать шаблон</a>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</section>
  <section id="admin-modal-contract-template-fl" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="admin-contract-template-fl-title">
    <div class="wf-modal__dialog wf-modal__dialog--form">
      <header class="wf-modal__header">
        <h2 id="admin-contract-template-fl-title" class="wf-modal__title">Шаблон договора — Физическое лицо</h2>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть">✕</a>
      </header>
      <div class="wf-modal__body">
        <form class="wf-form">
          <section class="wf-section">
            <h3>Параметры шаблона</h3>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-template-fl-client-type">Тип клиента</label>
                <select id="admin-template-fl-client-type">
                  <option value="fl" selected>Физическое лицо</option>
                  <option value="yl">Юридическое лицо</option>
                </select>
              </div>
              <div class="wf-field">
                <label for="admin-template-fl-status">Статус шаблона</label>
                <select id="admin-template-fl-status">
                  <option value="active" selected>Активен</option>
                  <option value="draft">Черновик</option>
                  <option value="archived">Архивирован</option>
                </select>
              </div>
            </div>
            <div class="wf-field">
              <label for="admin-template-fl-name">Название шаблона</label>
              <input id="admin-template-fl-name" type="text" value="Долгосрочная парковка (ФЛ)" placeholder="Название шаблона договора">
            </div>
            <div class="wf-field">
              <label for="admin-template-fl-code">Идентификатор шаблона в CRM</label>
              <input id="admin-template-fl-code" type="text" value="TEMPLATE_FL_LONG" placeholder="Код / ID шаблона в CRM">
            </div>
            <div class="wf-field">
              <label for="admin-template-fl-description">Комментарий для CRM и сотрудников</label>
              <textarea id="admin-template-fl-description" rows="3" placeholder="Например: шаблон долгосрочного договора для ФЛ, без ЭДО">Шаблон долгосрочного договора для физических лиц. Используется при оформлении договоров на парковочные места.</textarea>
            </div>
            <p class="wf-muted">
              Текстовая часть договора хранится и редактируется в CRM (Word/шаблон конструктора договоров).
              В этой форме настраиваются метаданные и отображение шаблона в интерфейсе панели администратора.
            </p>
            <p class="wf-muted">
              Текущая версия в CRM: <strong>v1.0 от 15.02.2026</strong>. При обновлении шаблона в CRM при необходимости обновите описание и статус здесь.
            </p>
          </section>
          <div class="wf-actions">
            <button type="submit" class="wf-btn">Сохранить настройки шаблона</button>
            <a href="#main-content" class="wf-btn wf-btn-secondary">Отмена</a>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section id="admin-modal-contract-template-yl" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="admin-contract-template-yl-title">
    <div class="wf-modal__dialog wf-modal__dialog--form">
      <header class="wf-modal__header">
        <h2 id="admin-contract-template-yl-title" class="wf-modal__title">Шаблон договора — Юридическое лицо</h2>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть">✕</a>
      </header>
      <div class="wf-modal__body">
        <form class="wf-form">
          <section class="wf-section">
            <h3>Параметры шаблона</h3>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-template-yl-client-type">Тип клиента</label>
                <select id="admin-template-yl-client-type">
                  <option value="fl">Физическое лицо</option>
                  <option value="yl" selected>Юридическое лицо</option>
                </select>
              </div>
              <div class="wf-field">
                <label for="admin-template-yl-status">Статус шаблона</label>
                <select id="admin-template-yl-status">
                  <option value="active" selected>Активен</option>
                  <option value="draft">Черновик</option>
                  <option value="archived">Архивирован</option>
                </select>
              </div>
            </div>
            <div class="wf-field">
              <label for="admin-template-yl-name">Название шаблона</label>
              <input id="admin-template-yl-name" type="text" value="Долгосрочная парковка (ЮЛ)" placeholder="Название шаблона договора">
            </div>
            <div class="wf-field">
              <label for="admin-template-yl-code">Идентификатор шаблона в CRM</label>
              <input id="admin-template-yl-code" type="text" value="TEMPLATE_YL_LONG" placeholder="Код / ID шаблона в CRM">
            </div>
            <div class="wf-field">
              <label for="admin-template-yl-description">Комментарий для CRM и сотрудников</label>
              <textarea id="admin-template-yl-description" rows="3" placeholder="Например: шаблон долгосрочного договора для ЮЛ, с реквизитами организации">Шаблон долгосрочного договора для юридических лиц. Включает реквизиты организации и условия корпоративного обслуживания.</textarea>
            </div>
            <p class="wf-muted">
              Текстовая часть договора хранится и редактируется в CRM/конструкторе договоров.
              Здесь настраиваются только метаданные и статус, используемые в панели администратора и при выборе шаблона.
            </p>
            <p class="wf-muted">
              Текущая версия в CRM: <strong>v1.0 от 15.02.2026</strong>. При изменении версии обновите описание и статус.
            </p>
          </section>
          <div class="wf-actions">
            <button type="submit" class="wf-btn">Сохранить настройки шаблона</button>
            <a href="#main-content" class="wf-btn wf-btn-secondary">Отмена</a>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section id="admin-modal-contract-template-new" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="admin-contract-template-new-title">
    <div class="wf-modal__dialog wf-modal__dialog--form">
      <header class="wf-modal__header">
        <h2 id="admin-contract-template-new-title" class="wf-modal__title">Создать новый шаблон договора</h2>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть">✕</a>
      </header>
      <div class="wf-modal__body">
        <form class="wf-form">
          <section class="wf-section">
            <h3>Параметры шаблона</h3>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-template-new-client-type">Тип клиента</label>
                <select id="admin-template-new-client-type">
                  <option value="fl">Физическое лицо</option>
                  <option value="yl">Юридическое лицо</option>
                </select>
              </div>
              <div class="wf-field">
                <label for="admin-template-new-status">Статус шаблона</label>
                <select id="admin-template-new-status">
                  <option value="active">Активен</option>
                  <option value="draft" selected>Черновик</option>
                  <option value="archived">Архивирован</option>
                </select>
              </div>
            </div>
            <div class="wf-field">
              <label for="admin-template-new-name">Название шаблона</label>
              <input id="admin-template-new-name" type="text" placeholder="Например: Долгосрочная парковка (ФЛ, льготный)">
            </div>
            <div class="wf-field">
              <label for="admin-template-new-code">Идентификатор шаблона в CRM</label>
              <input id="admin-template-new-code" type="text" placeholder="Код / ID шаблона в CRM">
            </div>
            <div class="wf-field">
              <label for="admin-template-new-description">Комментарий для CRM и сотрудников</label>
              <textarea id="admin-template-new-description" rows="3" placeholder="Опишите назначение шаблона, особенности условий и использования."></textarea>
            </div>
            <p class="wf-muted">
              После создания шаблона не забудьте настроить текст договора в CRM/конструкторе договоров и связать его с указанным идентификатором.
            </p>
          </section>
          <div class="wf-actions">
            <button type="submit" class="wf-btn">Создать шаблон</button>
            <a href="#main-content" class="wf-btn wf-btn-secondary">Отмена</a>
          </div>
        </form>
      </div>
    </div>
  </section>
{% endblock %}
