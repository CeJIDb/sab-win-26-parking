{% extends "layouts/admin.njk" %}

{% set current_nav = 'admin-contracts' %}

{% block title %}Договоры — ЛК админа{% endblock %}
{% block header_subtitle %}Управление договорами{% endblock %}
{% block content %}
<h2>Управление договорами</h2>

<section class="wf-section">
  <h3>Фильтры по договорам</h3>
  <form class="wf-form sessions-filters">
    <div class="filters-row">
      <div class="wf-field">
        <label for="search-contract-admin-number">№ договора</label>
        <input id="search-contract-admin-number" type="text" placeholder="Например, Д‑045">
      </div>
      <div class="wf-field">
        <label for="search-contract-admin-client">Клиент</label>
        <input id="search-contract-admin-client" type="text" placeholder="ФИО или название организации">
      </div>
      <div class="wf-field">
        <label for="search-contract-admin-status">Статус договора</label>
        <select id="search-contract-admin-status">
          <option value="">Любой</option>
          <option value="active">Активен</option>
          <option value="ending-soon">Скоро истекает</option>
          <option value="finished">Завершён</option>
          <option value="overdue">Просрочка</option>
        </select>
      </div>
      <div class="filter-actions">
        <button type="submit">Показать</button>
      </div>
    </div>
  </form>
</section>

<section class="wf-section">
  <h3>Реестр договоров</h3>
  <div class="wf-table-wrap">
    <table class="wf-table">
      <thead>
        <tr>
          <th>№ договора</th>
          <th>Клиент</th>
          <th>Период</th>
          <th>Статус договора</th>
          <th>Задолженность</th>
          <th>ТС / ПМ</th>
          <th>Действия</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Д‑045</td>
          <td>Иванов Иван Иванович</td>
          <td>01.01.2026–31.12.2026</td>
          <td><span class="wf-badge">Активен</span></td>
          <td>Нет</td>
          <td>2 ТС, 2 ПМ</td>
          <td>
            <a href="#admin-contract-modal" class="wf-btn">Просмотр</a>
          </td>
        </tr>
        <tr>
          <td>Д‑052</td>
          <td>ООО «Ромашка»</td>
          <td>15.02.2026–14.05.2026</td>
          <td><span class="wf-badge">Скоро истекает</span></td>
          <td>Просрочка 2 дня</td>
          <td>5 ТС, 4 ПМ</td>
          <td>
            <a href="#admin-contract-modal" class="wf-btn">Просмотр</a>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

{% include "partials/admin-contract-modal.njk" %}

<section class="wf-section">
  <h3>Шаблоны договоров</h3>
  <p class="wf-muted">Типовые шаблоны договоров, которые используются при оформлении для разных типов клиентов.</p>
  <div class="wf-table-wrap">
    <table class="wf-table">
      <thead>
        <tr>
          <th>Тип клиента</th>
          <th>Название шаблона</th>
          <th>Действия</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Физическое лицо</td>
          <td>Долгосрочная парковка (ФЛ)</td>
          <td>
            <button type="button">Изменить шаблон для ФЛ</button>
          </td>
        </tr>
        <tr>
          <td>Юридическое лицо</td>
          <td>Долгосрочная парковка (ЮЛ)</td>
          <td>
            <button type="button">Изменить шаблон для ЮЛ</button>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</section>
{% endblock %}
