{% extends "layouts/site.njk" %}

{% block title %}Регистрация — Цифровая платформа парковки{% endblock %}

{% block content %}
  <section class="wf-section wf-section--no-bg" aria-labelledby="register-heading">
    <h2 id="register-heading">Регистрация нового клиента</h2>
    <p class="wf-error" role="alert" aria-live="polite" aria-hidden="true"></p>
    <form class="wf-form" action="../client/dashboard.html" method="get">
      <fieldset class="wf-fieldset">
        <legend class="wf-fieldset__legend">Контактные данные</legend>
        <div class="wf-field">
          <label for="reg-phone">Телефон</label>
          <input id="reg-phone" type="tel" placeholder="+7 …" required>
        </div>
        <div class="wf-field">
          <label for="reg-phone-code">Код подтверждения телефона</label>
          <input id="reg-phone-code" type="text" placeholder="Введите код из СМС" inputmode="numeric" maxlength="6">
          <div class="wf-actions" style="margin-top: 0.5rem;">
            <button type="button" class="wf-btn">Отправить код подтверждения</button>
            <button type="button" class="wf-btn wf-btn-secondary">Подтвердить</button>
          </div>
        </div>
        <div class="wf-field">
          <label for="reg-email">E-mail (необязательно)</label>
          <input id="reg-email" type="email" placeholder="email@example.com">
        </div>
      </fieldset>

      <fieldset class="wf-fieldset">
        <legend class="wf-fieldset__legend">Пароль</legend>
        <div class="wf-field">
          <label for="reg-password">Пароль</label>
          <input id="reg-password" type="password" placeholder="Задайте пароль" required>
        </div>
        <div class="wf-field">
          <label for="reg-password-confirm">Подтверждение пароля</label>
          <input id="reg-password-confirm" type="password" placeholder="Повторите пароль" required>
        </div>
      </fieldset>

      <fieldset class="wf-fieldset">
        <legend class="wf-fieldset__legend">ФИО</legend>
        <div class="wf-field">
          <label for="reg-last-name">Фамилия</label>
          <input id="reg-last-name" type="text" placeholder="Иванов">
        </div>
        <div class="wf-field">
          <label for="reg-first-name">Имя</label>
          <input id="reg-first-name" type="text" placeholder="Иван">
        </div>
        <div class="wf-field">
          <label for="reg-middle-name">Отчество (необязательно)</label>
          <input id="reg-middle-name" type="text" placeholder="Иванович">
        </div>
      </fieldset>

      <fieldset class="wf-fieldset">
        <legend class="wf-fieldset__legend">Транспортные средства (необязательно)</legend>
        <p class="wf-muted">Можно добавить ТС сейчас или позже в личном кабинете.</p>
        <div class="wf-actions">
          <a href="#vehicle-add-modal" class="wf-btn">Добавить ТС</a>
        </div>
        <div id="reg-vehicles-list" class="wf-card" aria-live="polite" hidden>
          <p class="wf-muted">Список добавленных ТС будет отображаться здесь.</p>
        </div>
      </fieldset>

      <fieldset class="wf-fieldset">
        <legend class="wf-fieldset__legend">Льготные категории и ОВЗ (необязательно)</legend>
        <p class="wf-muted">Можно указать и загрузить документы сейчас или позже в <a href="../client/profile.html">профиле личного кабинета</a>.</p>
        <div class="wf-field">
          <label for="reg-benefit-doc">Документ, подтверждающий льготу или статус ОВЗ (фото, скан)</label>
          <input id="reg-benefit-doc" type="file" accept="image/*,.pdf" aria-describedby="reg-benefit-doc-hint">
          <p id="reg-benefit-doc-hint" class="wf-muted">Формат: изображение (JPG, PNG и др.) или PDF. Макс. размер уточняется при отправке.</p>
        </div>
      </fieldset>

      <fieldset class="wf-fieldset">
        <legend class="wf-fieldset__legend">Настройки уведомлений</legend>
        <div class="wf-field wf-field--checkbox">
          <label for="reg-notify-main">
            <input id="reg-notify-main" type="checkbox" checked>
            <span>Соглашаюсь получать уведомления о статусах парковочных сессий, бронирований, договоров и оплат</span>
          </label>
        </div>
        <div class="wf-field wf-field--checkbox">
          <label for="reg-marketing">
            <input id="reg-marketing" type="checkbox">
            <span>Маркетинговые рассылки: акции, новости парковки и партнёров</span>
          </label>
        </div>
      </fieldset>

      <fieldset class="wf-fieldset">
        <legend class="wf-fieldset__legend">Согласия</legend>
        <div class="wf-field wf-field--checkbox">
          <label for="reg-oferta">
            <input id="reg-oferta" type="checkbox" required>
            Согласен с <a href="rules.html">правилами парковки</a> (оферта)
          </label>
        </div>
        <div class="wf-field wf-field--checkbox">
          <label for="reg-pdn">
            <input id="reg-pdn" type="checkbox" required>
            Даю согласие на обработку персональных данных
          </label>
        </div>
      </fieldset>

      <div class="wf-actions">
        <button type="submit" class="wf-btn">Зарегистрироваться</button>
        <a href="login.html" class="wf-btn wf-btn-secondary">Уже есть аккаунт — войти</a>
      </div>
    </form>
  </section>

  {% include "partials/vehicles-add-modal.njk" %}
{% endblock %}

