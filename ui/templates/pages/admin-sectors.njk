{% extends "layouts/admin.njk" %}

{% set current_nav = 'admin-sectors' %}

{% block title %}Секторы и ПМ — ЛК админа{% endblock %}
{% block header_breadcrumbs %}<a href="sessions.html">Парковка</a><span class="wf-breadcrumbs__sep">/</span><span class="wf-breadcrumbs__current">Секторы и ПМ</span>{% endblock %}

{% block auxiliary_nav %}
  {% set nav_current = current_nav %}
  {% include "partials/nav-parking.njk" %}
{% endblock %}

{% block content %}
  <div class="wf-page-head">
    <button type="button" class="wf-back">Назад</button>
    <h2>Управление секторами и парковочными местами</h2>
  </div>

  <section class="wf-section">
    <h3>Карта парковки по секторам</h3>
    <p class="wf-muted">Нажмите на сектор на карте, чтобы открыть его настройки и распределить места.</p>
    <div class="wf-parking-map" role="img" aria-label="Схема парковки по секторам">
      <div class="wf-parking-map__zones">
        <div class="wf-parking-map__column">
          <a href="#admin-modal-sector-settings" class="wf-parking-map__zone" id="sector-block-A">
            <p class="wf-parking-map__zone-title">Сектор А — 200 мест</p>
            <p class="wf-parking-map__zone-meta">забронировано: 140 (ФЛ/ЮЛ) · заблокировано: 10</p>
          </a>
          <a href="#admin-modal-sector-settings" class="wf-parking-map__zone" id="sector-block-B">
            <p class="wf-parking-map__zone-title">Сектор Б — 220 мест</p>
            <p class="wf-parking-map__zone-meta">забронировано: 160 (ФЛ/ЮЛ) · заблокировано: 20</p>
          </a>
        </div>
        <div class="wf-parking-map__column">
          <a href="#admin-modal-sector-settings" class="wf-parking-map__zone" id="sector-block-C">
            <p class="wf-parking-map__zone-title">Сектор В — 180 мест</p>
            <p class="wf-parking-map__zone-meta">забронировано: 110 (ФЛ/ЮЛ) · заблокировано: 15</p>
          </a>
          <a href="#admin-modal-sector-settings" class="wf-parking-map__zone" id="sector-block-D">
            <p class="wf-parking-map__zone-title">Резерв / служебные — 0 мест</p>
            <p class="wf-parking-map__zone-meta">используются под технику и обслуживание</p>
          </a>
        </div>
      </div>
      <p class="wf-parking-map__total">Всего 600 мест · забронировано: 410 · нераспределено: 150 · заблокировано: 40.</p>
    </div>
    <div class="wf-actions" style="margin-top: 1rem;">
      <a href="#admin-modal-sector-add" class="wf-btn">Добавить сектор</a>
    </div>
  </section>

  <section class="wf-section">
    <h3>Парковочные места</h3>
    <p class="wf-muted">Отображаются только закреплённые за ФЛ и ЮЛ парковочные места.</p>
    <form class="wf-form sessions-filters" aria-label="Фильтры по закреплённым ПМ">
      <div class="filters-row">
        <div class="wf-field">
          <label for="search-sector-name">Сектор</label>
          <select id="search-sector-name">
            <option value="">Любой</option>
            <option value="A">Сектор А</option>
            <option value="B">Сектор Б</option>
            <option value="C">Сектор В</option>
          </select>
        </div>
        <div class="wf-field">
          <label for="search-sector-pm">Парковочное место</label>
          <input id="search-sector-pm" type="text" placeholder="Например, ПМ 101">
        </div>
        <div class="wf-field">
          <label for="search-sector-client-type">Тип клиента</label>
          <select id="search-sector-client-type">
            <option value="">Любой</option>
            <option value="fl">ФЛ</option>
            <option value="yl">ЮЛ</option>
          </select>
        </div>
        <div class="wf-field">
          <label for="search-spot-status">Статус места</label>
          <select id="search-spot-status">
            <option value="">Любой</option>
            <option value="active">Активно</option>
            <option value="blocked">Заблокировано</option>
          </select>
        </div>
        <div class="filter-actions">
          <button type="submit">Применить</button>
          <button type="button">Сбросить</button>
        </div>
      </div>
    </form>
    <div class="wf-actions" style="margin-top: 0.75rem;">
      <a href="#admin-modal-sector-pm" class="wf-btn">Создать ПМ</a>
    </div>
    <div class="wf-table-wrap">
      <table class="wf-table">
        <thead>
          <tr>
            <th scope="col">Сектор</th>
            <th scope="col">Парковочное место</th>
            <th scope="col">Тип клиента</th>
            <th scope="col">Статус договора</th>
            <th scope="col">Договор / клиент</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Сектор А</td>
            <td><a href="#admin-modal-sector-pm">ПМ 101</a></td>
            <td>ФЛ</td>
            <td><span class="wf-badge">Активен</span></td>
            <td><a href="#admin-modal-contract-view">Д-045</a>, <a href="#admin-modal-client-fl">Иванов И.И.</a></td>
          </tr>
          <tr>
            <td>Сектор А</td>
            <td><a href="#admin-modal-sector-pm">ПМ 103</a></td>
            <td>ЮЛ</td>
            <td><span class="wf-badge">Активен</span></td>
            <td><a href="#admin-modal-contract-view">Д-078</a>, <a href="#admin-modal-client-yl">ООО «СтройИнвест»</a></td>
          </tr>
          <tr>
            <td>Сектор Б</td>
            <td><a href="#admin-modal-sector-pm">ПМ 201</a></td>
            <td>ФЛ</td>
            <td><span class="wf-badge">Заблокировано</span></td>
            <td><a href="#admin-modal-contract-view">Д-102</a>, <a href="#admin-modal-client-fl">Петров П.П.</a> (задолженность)</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section id="admin-modal-sector-settings" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="admin-sector-settings-title">
    <div class="wf-modal__dialog wf-modal__dialog--form">
      <header class="wf-modal__header">
        <h2 id="admin-sector-settings-title" class="wf-modal__title">Настройки сектора</h2>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть">✕</a>
      </header>
      <div class="wf-modal__body">
        <form class="wf-form">
          <p class="wf-error" role="alert" aria-live="polite" aria-hidden="true"></p>
          <section class="wf-section">
            <h3>Основные параметры сектора</h3>
            <div class="wf-field">
              <label for="admin-sector-name">Название сектора</label>
              <input id="admin-sector-name" type="text" value="Сектор А">
            </div>
            <div class="wf-field">
              <label for="admin-sector-total">Всего мест в секторе</label>
              <input id="admin-sector-total" type="number" min="0" value="200">
            </div>
            <div class="wf-field">
              <label for="admin-sector-long">Мест, закреплённых по договорам ФЛ/ЮЛ</label>
              <input id="admin-sector-long" type="number" min="0" value="140">
            </div>
            <div class="wf-field">
              <label for="admin-sector-blocked">Заблокированных мест</label>
              <input id="admin-sector-blocked" type="number" min="0" value="10">
            </div>
            <p class="wf-muted">
              Нераспределённые места рассчитываются как
              <strong>Всего − закреплённые − заблокированные</strong> и отображаются на карте и в отчётах.
            </p>
            <div class="wf-field">
              <label for="admin-sector-comment">Комментарий к сектору</label>
              <input id="admin-sector-comment" type="text" placeholder="Например: уровень 1, близко к КПП‑1, преимущественно ЮЛ">
            </div>
          </section>
          <div class="wf-actions">
            <button type="submit">Сохранить сектор</button>
            <a href="#admin-modal-sector-delete" class="wf-btn wf-btn-secondary">Удалить сектор</a>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section id="admin-modal-sector-delete" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="admin-sector-delete-title">
    <div class="wf-modal__dialog wf-section">
      <header class="wf-modal__header">
        <h3 id="admin-sector-delete-title">Удалить сектор</h3>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть окно">✕</a>
      </header>
      <div class="wf-body">
        <p>
          Вы уверены, что хотите удалить <strong>Сектор А</strong> и все связанные с ним парковочные места?
        </p>
        <p class="wf-muted">
          При удалении сектора закреплённые парковочные места будут удалены из реестра, а данные по договорам и сессиям сохранятся в истории.
          Точное поведение зависит от настроек интеграции и должно быть подтверждено в регламенте.
        </p>
        <div class="wf-actions">
          <button type="button" class="wf-btn">Подтвердить удаление сектора</button>
          <a href="#admin-modal-sector-settings" class="wf-btn wf-btn-secondary">Отмена</a>
        </div>
      </div>
    </div>
  </section>

  <section id="admin-modal-sector-add" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="admin-sector-add-title">
    <div class="wf-modal__dialog wf-modal__dialog--form">
      <header class="wf-modal__header">
        <h2 id="admin-sector-add-title" class="wf-modal__title">Добавить сектор</h2>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть">✕</a>
      </header>
      <div class="wf-modal__body">
        <form class="wf-form">
          <p class="wf-error" role="alert" aria-live="polite" aria-hidden="true"></p>
          <div class="wf-field">
            <label for="admin-sector-new-name">Название сектора</label>
            <input id="admin-sector-new-name" type="text" placeholder="Например, Сектор Г">
          </div>
          <div class="wf-field">
            <label for="admin-sector-new-count">Всего мест в секторе</label>
            <input id="admin-sector-new-count" type="number" min="1" value="50">
          </div>
          <div class="wf-grid wf-grid--two">
            <div class="wf-field">
              <label for="admin-sector-new-long">Планируется закрепить по договорам</label>
              <input id="admin-sector-new-long" type="number" min="0" value="40">
            </div>
            <div class="wf-field">
              <label for="admin-sector-new-blocked">Зарезервировать/заблокировать</label>
              <input id="admin-sector-new-blocked" type="number" min="0" value="5">
            </div>
          </div>
          <p class="wf-muted">
            Нераспределённые места будут доступны для дальнейшего планирования и могут быть распределены между ФЛ и ЮЛ позже.
          </p>
          <div class="wf-actions">
            <button type="submit">Создать сектор</button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section id="admin-modal-sector-pm" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="admin-sector-title">
    <div class="wf-modal__dialog wf-modal__dialog--form">
      <header class="wf-modal__header">
        <h2 id="admin-sector-title" class="wf-modal__title">Настройки парковочного места</h2>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть">✕</a>
      </header>
      <div class="wf-modal__body">
        <form class="wf-form">
          <p class="wf-error" role="alert" aria-live="polite" aria-hidden="true"></p>
          <section class="wf-section">
            <h3>Основная информация</h3>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-spot-sector">Сектор</label>
                <select id="admin-spot-sector">
                  <option value="A" selected>Сектор А</option>
                  <option value="B">Сектор Б</option>
                  <option value="C">Сектор В</option>
                </select>
              </div>
              <div class="wf-field">
                <label for="admin-spot-number">Парковочное место</label>
                <input id="admin-spot-number" type="text" value="ПМ 101">
              </div>
            </div>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-spot-type">Тип места</label>
                <select id="admin-spot-type">
                  <option value="long" selected>Долгосрочное</option>
                  <option value="guest">Гостевое</option>
                </select>
              </div>
              <div class="wf-field">
                <label for="admin-spot-status-edit">Статус</label>
                <select id="admin-spot-status-edit">
                  <option value="free">Свободно</option>
                  <option value="occupied" selected>Занято</option>
                  <option value="blocked">Заблокировано</option>
                </select>
              </div>
            </div>
          </section>

          <section class="wf-section">
            <h3>Привязка к договору</h3>
            <div class="wf-field">
              <label for="admin-spot-contract">Договор / комментарий</label>
              <input id="admin-spot-contract" type="text" value="Д-045, Иванов И.И.">
            </div>
          </section>

          <div class="wf-actions">
            <button type="submit">Сохранить изменения</button>
            <a href="#admin-modal-contract-view" class="wf-btn">Договор</a>
            <a href="#admin-modal-client-fl" class="wf-btn">Карточка клиента</a>
            <a href="#admin-modal-sector-pm-delete" class="wf-btn wf-btn-secondary">Удалить ПМ</a>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section id="admin-modal-sector-pm-delete" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="admin-sector-pm-delete-title">
    <div class="wf-modal__dialog wf-section">
      <header class="wf-modal__header">
        <h3 id="admin-sector-pm-delete-title">Удалить парковочное место</h3>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть окно">✕</a>
      </header>
      <div class="wf-body">
        <p>
          Вы уверены, что хотите удалить <strong>ПМ 101 в Секторе А</strong> из реестра парковочных мест?
        </p>
        <p class="wf-muted">
          Если парковочное место используется в активных договорах или бронированиях, удаление может потребовать дополнительных действий со стороны администратора
          и не должно нарушать учёт операций. Фактическое поведение определяется интеграцией и регламентами.
        </p>
        <div class="wf-actions">
          <button type="button" class="wf-btn">Подтвердить удаление ПМ</button>
          <a href="#admin-modal-sector-pm" class="wf-btn wf-btn-secondary">Отмена</a>
        </div>
      </div>
    </div>
  </section>

  {% include "partials/admin-contract-modal.njk" %}
  {% include "partials/admin-client-modal.njk" %}
{% endblock %}
