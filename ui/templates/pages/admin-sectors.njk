{% extends "layouts/admin.njk" %}

{% set current_nav = 'admin-sectors' %}

{% block title %}Секторы и ПМ — ЛК админа{% endblock %}
{% block header_subtitle %}Секторы и парковочные места{% endblock %}

{% block content %}
  <h2>Управление секторами и парковочными местами</h2>

  <section class="wf-section">
    <h3>Карта парковки по секторам</h3>
    <p class="wf-muted">Нажмите на сектор, чтобы настроить количество мест и параметры. Свободные места можно распределять из пула.</p>
    <div class="wf-parking-map" role="img" aria-label="Схема парковки по секторам">
      <a href="#admin-sector-settings-modal" class="wf-parking-map__sector wf-parking-map__sector--A" id="sector-block-A">
        <span class="wf-parking-map__sector-name">Сектор А</span>
        <span class="wf-parking-map__sector-stats">24 места · 18 занято</span>
      </a>
      <a href="#admin-sector-settings-modal" class="wf-parking-map__sector wf-parking-map__sector--B" id="sector-block-B">
        <span class="wf-parking-map__sector-name">Сектор Б</span>
        <span class="wf-parking-map__sector-stats">32 места · 28 занято</span>
      </a>
      <a href="#admin-sector-settings-modal" class="wf-parking-map__sector wf-parking-map__sector--C" id="sector-block-C">
        <span class="wf-parking-map__sector-name">Сектор В</span>
        <span class="wf-parking-map__sector-stats">16 мест · 12 занято</span>
      </a>
    </div>
    <div class="wf-actions" style="margin-top: 1rem;">
      <a href="#admin-sector-add-modal" class="wf-btn">Добавить сектор</a>
      <button type="button" class="wf-btn">Удалить сектор</button>
    </div>
  </section>

  <section class="wf-section">
    <h3>Пул свободных мест</h3>
    <p class="wf-muted">Места без привязки к сектору. Распределите их по секторам или создайте новый сектор.</p>
    <div class="wf-card" style="max-width: 28rem;">
      <p><strong>Свободных мест в пуле:</strong> 12</p>
      <form class="wf-form" style="margin-top: 0.75rem;">
        <div class="wf-grid wf-grid--two">
          <div class="wf-field">
            <label for="pool-to-sector">Распределить в сектор</label>
            <select id="pool-to-sector">
              <option value="">Выберите сектор</option>
              <option value="A">Сектор А</option>
              <option value="B">Сектор Б</option>
              <option value="C">Сектор В</option>
            </select>
          </div>
          <div class="wf-field">
            <label for="pool-count">Количество мест</label>
            <input id="pool-count" type="number" min="1" value="1">
          </div>
        </div>
        <div class="wf-actions">
          <button type="submit">Распределить из пула</button>
        </div>
      </form>
    </div>
  </section>

  <section class="wf-section">
    <h3>Фильтры по секторам и ПМ</h3>
    <form class="wf-form sessions-filters">
      <div class="filters-row">
        <div class="wf-field">
          <label for="search-sector-name">Сектор</label>
          <select id="search-sector-name">
            <option value="">Любой</option>
            <option value="A">Сектор А</option>
            <option value="B">Сектор Б</option>
            <option value="C">Сектор В</option>
          </select>
        </div>
        <div class="wf-field">
          <label for="search-spot-type">Тип места</label>
          <select id="search-spot-type">
            <option value="">Любой</option>
            <option value="long">Долгосрочное</option>
            <option value="guest">Гостевое</option>
          </select>
        </div>
        <div class="wf-field">
          <label for="search-spot-status">Статус места</label>
          <select id="search-spot-status">
            <option value="">Любой</option>
            <option value="free">Свободно</option>
            <option value="occupied">Занято</option>
            <option value="blocked">Заблокировано</option>
          </select>
        </div>
        <div class="filter-actions">
          <button type="submit">Показать</button>
        </div>
      </div>
    </form>
  </section>

  <section class="wf-section">
    <h3>Реестр секторов и парковочных мест</h3>
    <p class="wf-muted">Прототип реестра ПМ: по каждому месту видно сектор, статус занятости и привязку к договору.</p>
    <div class="wf-table-wrap">
      <table class="wf-table">
        <thead>
          <tr>
            <th>Сектор</th>
            <th>Парковочное место</th>
            <th>Тип</th>
            <th>Статус</th>
            <th>Привязан к договору</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Сектор А</td>
            <td>ПМ 101</td>
            <td>Долгосрочное</td>
            <td><span class="wf-badge">Занято</span></td>
            <td>Д‑045, Иванов И.И.</td>
            <td><a href="#admin-sector-modal" class="wf-btn">Настроить</a></td>
          </tr>
          <tr>
            <td>Сектор А</td>
            <td>ПМ 102</td>
            <td>Гостевое</td>
            <td><span class="wf-badge">Свободно</span></td>
            <td>—</td>
            <td><a href="#admin-sector-modal" class="wf-btn">Настроить</a></td>
          </tr>
          <tr>
            <td>Сектор Б</td>
            <td>ПМ 201</td>
            <td>Долгосрочное</td>
            <td><span class="wf-badge">Заблокировано</span></td>
            <td>Резерв под ремонт</td>
            <td><a href="#admin-sector-modal" class="wf-btn">Настроить</a></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section id="admin-sector-settings-modal" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="admin-sector-settings-title">
    <div class="wf-modal__dialog wf-modal__dialog--form">
      <header class="wf-modal__header">
        <h2 id="admin-sector-settings-title" class="wf-modal__title">Настройки сектора</h2>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть">✕</a>
      </header>
      <div class="wf-modal__body">
        <form class="wf-form">
          <section class="wf-section">
            <h3>Основные параметры сектора</h3>
            <div class="wf-field">
              <label for="admin-sector-name">Название сектора</label>
              <input id="admin-sector-name" type="text" value="Сектор А">
            </div>
            <div class="wf-field">
              <label for="admin-sector-total">Всего мест в секторе</label>
              <input id="admin-sector-total" type="number" min="0" value="24">
            </div>
            <div class="wf-field">
              <label for="admin-sector-long">Из них долгосрочных (по договору)</label>
              <input id="admin-sector-long" type="number" min="0" value="18">
            </div>
            <div class="wf-field">
              <label for="admin-sector-guest">Гостевых (почасовых)</label>
              <input id="admin-sector-guest" type="number" min="0" value="6">
            </div>
            <div class="wf-field">
              <label for="admin-sector-comment">Комментарий</label>
              <input id="admin-sector-comment" type="text" placeholder="Например: уровень 1, въезд с северной стороны">
            </div>
          </section>
          <div class="wf-actions">
            <button type="submit">Сохранить сектор</button>
            <button type="button">Удалить сектор</button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section id="admin-sector-add-modal" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="admin-sector-add-title">
    <div class="wf-modal__dialog wf-modal__dialog--form">
      <header class="wf-modal__header">
        <h2 id="admin-sector-add-title" class="wf-modal__title">Добавить сектор</h2>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть">✕</a>
      </header>
      <div class="wf-modal__body">
        <form class="wf-form">
          <div class="wf-field">
            <label for="admin-sector-new-name">Название сектора</label>
            <input id="admin-sector-new-name" type="text" placeholder="Например, Сектор Г">
          </div>
          <div class="wf-field">
            <label for="admin-sector-new-count">Количество мест (взять из пула)</label>
            <input id="admin-sector-new-count" type="number" min="1" value="1">
          </div>
          <p class="wf-muted">Места будут созданы в пуле и перенесены в новый сектор. При необходимости сначала распределите места из пула.</p>
          <div class="wf-actions">
            <button type="submit">Создать сектор</button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section id="admin-sector-modal" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="admin-sector-title">
    <div class="wf-modal__dialog wf-modal__dialog--form">
      <header class="wf-modal__header">
        <h2 id="admin-sector-title" class="wf-modal__title">Настройки парковочного места</h2>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть">✕</a>
      </header>
      <div class="wf-modal__body">
        <form class="wf-form">
          <section class="wf-section">
            <h3>Основная информация</h3>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-spot-sector">Сектор</label>
                <input id="admin-spot-sector" type="text" value="Сектор А">
              </div>
              <div class="wf-field">
                <label for="admin-spot-number">Парковочное место</label>
                <input id="admin-spot-number" type="text" value="ПМ 101">
              </div>
            </div>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-spot-type">Тип места</label>
                <select id="admin-spot-type">
                  <option value="long" selected>Долгосрочное</option>
                  <option value="guest">Гостевое</option>
                </select>
              </div>
              <div class="wf-field">
                <label for="admin-spot-status-edit">Статус</label>
                <select id="admin-spot-status-edit">
                  <option value="free">Свободно</option>
                  <option value="occupied" selected>Занято</option>
                  <option value="blocked">Заблокировано</option>
                </select>
              </div>
            </div>
          </section>

          <section class="wf-section">
            <h3>Привязка к договору</h3>
            <div class="wf-field">
              <label for="admin-spot-contract">Договор / комментарий</label>
              <input id="admin-spot-contract" type="text" value="Д‑045, Иванов И.И.">
            </div>
          </section>

          <div class="wf-actions">
            <button type="submit">Сохранить изменения</button>
          </div>
        </form>
      </div>
    </div>
  </section>
{% endblock %}
