{% extends "layouts/lk.njk" %}

{% set current_nav = 'payment-settings' %}

{% block title %}Оплаты — ЛК клиента{% endblock %}
{% block header_subtitle %}История оплат и настройки автосписания{% endblock %}

{% block content %}
  <h2>Оплаты</h2>

  <section class="wf-section">
    <h3>Сводка по оплатам</h3>
    <p class="wf-muted">
      На текущий момент: <strong>нет просроченных счетов</strong>, <strong>2 счёта к оплате</strong>, автосписание по договорам включено.
    </p>
  </section>

  <section class="wf-section">
    <h3>Счета к оплате</h3>
    <p class="wf-muted">Здесь отображаются выставленные, но ещё не оплаченные счета по договорам, бронированиям и сессиям. По каждому счету можно перейти к оплате или посмотреть детали.</p>
    <div class="wf-table-wrap">
      <table class="wf-table">
        <thead>
          <tr>
            <th>Дата выставления</th>
            <th>Описание</th>
            <th>Сумма</th>
            <th>Статус</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>25.02.2026</td>
            <td>Счёт по договору №1001 за март 2026</td>
            <td>4 500 ₽</td>
            <td>К оплате</td>
            <td>
              <a href="payment-external.html" class="wf-btn">Оплатить</a>
              <button type="button">Подробнее</button>
            </td>
          </tr>
          <tr>
            <td>24.02.2026</td>
            <td>Счёт за парковочные сессии за 24.02.2026 (ТС А123БВ777)</td>
            <td>350 ₽</td>
            <td>Ожидает оплаты</td>
            <td>
              <a href="payment-external.html" class="wf-btn">Оплатить</a>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="wf-section">
    <h3>Настройки автосписания</h3>
    <form class="wf-form">
      <div class="wf-field wf-field--checkbox">
        <label for="pay-autopay-enabled">
          <input id="pay-autopay-enabled" type="checkbox" checked>
          <span>Разрешить автосписание по активным договорам</span>
        </label>
      </div>
      <div class="wf-field wf-field--checkbox">
        <label for="pay-autospay-sessions">
          <input id="pay-autospay-sessions" type="checkbox">
          <span>Разрешить автосписание по парковочным сессиям</span>
        </label>
      </div>
      <div class="wf-field">
        <label for="pay-autopay-limit">Лимит автосписания в месяц</label>
        <input id="pay-autopay-limit" type="text" placeholder="[сумма, ₽]">
        <p class="wf-notice">При достижении лимита новые списания требуют явного подтверждения.</p>
      </div>
      <div class="wf-field wf-field--checkbox">
        <label for="pay-autopay-notify">
          <input id="pay-autopay-notify" type="checkbox" checked>
          <span>Отправлять уведомления об автосписаниях и ошибках списания</span>
        </label>
      </div>
      <div class="wf-actions">
        <button type="submit">Сохранить настройки</button>
      </div>
    </form>
  </section>

  <section class="wf-section">
    <h3>История оплат</h3>
    <p class="wf-muted">Здесь отображаются последние успешные и отклонённые платежи по сессиям, бронированиям и договорам.</p>
    <div class="wf-table-wrap">
      <table class="wf-table">
        <thead>
          <tr>
            <th>Дата и время</th>
            <th>Тип</th>
            <th>Описание</th>
            <th>Сумма</th>
            <th>Статус</th>
            <th>Чек</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>24.02.2026 10:15</td>
            <td>Сессия</td>
            <td>Парковочная сессия №S-1001 (ТС А123БВ777)</td>
            <td>350 ₽</td>
            <td>Успешно</td>
            <td><a href="#" aria-label="Открыть чек по оплате S-1001">Скачать чек</a></td>
          </tr>
          <tr>
            <td>23.02.2026 18:40</td>
            <td>Бронирование</td>
            <td>Бронь №B-204 на ПМ 12, сектор A</td>
            <td>500 ₽</td>
            <td>Успешно</td>
            <td><a href="#" aria-label="Открыть чек по бронированию B-204">Скачать чек</a></td>
          </tr>
          <tr>
            <td>22.02.2026 09:05</td>
            <td>Договор</td>
            <td>Оплата по договору №1001 за месяц</td>
            <td>4 500 ₽</td>
            <td>Успешно</td>
            <td><a href="#" aria-label="Открыть чек по оплате договора 1001">Скачать чек</a></td>
          </tr>
          <tr>
            <td>21.02.2026 21:30</td>
            <td>Сессия</td>
            <td>Парковочная сессия №S-0998 (ТС В456ГД177)</td>
            <td>300 ₽</td>
            <td>Отклонено</td>
            <td><a href="#" aria-label="Подробнее об ошибке оплаты S-0998">Подробнее</a></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="wf-section">
    <h3>Информация об оплате через внешний сервис</h3>
    <p class="wf-muted">
      Оплата всех счетов выполняется через защищённый платёжный сервис партнёра. Сохранённые карты и другие
      платёжные данные хранятся только на стороне платёжного сервиса и недоступны в личном кабинете парковки.
    </p>
    <p class="wf-muted">
      Продолжая оплату, вы переходите на страницу платёжного сервиса и соглашаетесь с его условиями
      обработки платежей. После завершения операции результат оплаты и чек будут отображены в разделе
      «Оплаты» вашего личного кабинета.
    </p>
  </section>
{% endblock %}
