{% extends "layouts/admin.njk" %}

{% set current_nav = 'admin-index' %}

{% block title %}Главная админа — Цифровая платформа парковки{% endblock %}

{% block content %}
  <h2>Главная</h2>

  <section class="wf-section">
    <h3>Ключевые показатели</h3>
    <div class="wf-grid">
      <section class="wf-card">
        <h3>Загрузка парковки</h3>
        <p><strong>Свободно:</strong> 32 из 600 ПМ</p>
        <p class="wf-muted">Сектор А — 75% занятости, сектор Б — 85%.</p>
        <p><a href="sectors.html" class="wf-btn">Перейти к секторам</a></p>
      </section>
      <section class="wf-card">
        <h3>Договоры и клиенты</h3>
        <p><strong>Активных договоров:</strong> 124</p>
        <p class="wf-muted">Из них 15 истекают в ближайшие 7 дней.</p>
        <p><a href="contracts.html" class="wf-btn">Открыть реестр договоров</a></p>
      </section>
      <section class="wf-card">
        <h3>Финансы</h3>
        <p><strong>Поступления за сегодня:</strong> 152 300 ₽</p>
        <p class="wf-muted">Просроченная задолженность: 12 договоров.</p>
        <p><a href="debts.html" class="wf-btn">Проверить задолженности</a></p>
      </section>
      <section class="wf-card">
        <h3>Обращения и инциденты</h3>
        <p><strong>Новых обращений:</strong> 3</p>
        <p class="wf-muted">Инцидентов «отказ во въезде» за сегодня: 2.</p>
        <p><a href="requests.html" class="wf-btn">Открыть обращения</a></p>
      </section>
    </div>
  </section>

  <section class="wf-section">
    <h3>Карта загрузки парковки</h3>
    <p class="wf-muted">Сводная карта текущей занятости по секторам и типам мест.</p>
    {% include "partials/parking-map-compact.njk" %}
  </section>
{% endblock %}
