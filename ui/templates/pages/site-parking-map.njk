{% extends "layouts/site.njk" %}

{% block title %}Карта свободных мест — Цифровая платформа парковки{% endblock %}

{% block content %}
  <h2>Количество свободных парковочных мест</h2>
  <!-- По Схема парковки AS-IS.md: два КПП (север, юг), зоны с типами и вместимостью, всего 600 мест -->
  <section class="wf-section">
    <h3>Схема парковки (AS-IS)</h3>
    <p class="wf-muted">Расположение сверху вниз: КПП север → зоны (две колонки) → КПП юг. Условные обозначения: блоки КПП — въезд/выезд; жёлтые блоки — зоны с типом и количеством мест.</p>
    <div class="wf-parking-map" role="img" aria-label="Схема парковки: КПП север и юг, зоны по типам и вместимости">
      <div class="wf-parking-map__kpp">КПП север</div>
      <div class="wf-parking-map__zones">
        <div class="wf-parking-map__column">
          <div class="wf-parking-map__zone" data-zone-type="ovz">
            <p class="wf-parking-map__zone-title">Места для лиц с ОВЗ</p>
            <p class="wf-parking-map__zone-meta">мест: 25 · свободно: [—]</p>
          </div>
          <div class="wf-parking-map__zone" data-zone-type="short">
            <p class="wf-parking-map__zone-title">Краткосрочная парковка</p>
            <p class="wf-parking-map__zone-meta">мест: 45 · свободно: [—]</p>
          </div>
          <div class="wf-parking-map__zone" data-zone-type="long">
            <p class="wf-parking-map__zone-title">Долгосрочная парковка ФЛ+ЮЛ</p>
            <p class="wf-parking-map__zone-meta">мест: 310 · свободно: [—]</p>
          </div>
          <div class="wf-parking-map__zone" data-zone-type="long">
            <p class="wf-parking-map__zone-title">Долгосрочная парковка ФЛ+ЮЛ</p>
            <p class="wf-parking-map__zone-meta">мест: 15 · свободно: [—]</p>
          </div>
          <div class="wf-parking-map__zone" data-zone-type="short">
            <p class="wf-parking-map__zone-title">Краткосрочная парковка</p>
            <p class="wf-parking-map__zone-meta">мест: 35 · свободно: [—]</p>
          </div>
        </div>
        <div class="wf-parking-map__column">
          <div class="wf-parking-map__zone" data-zone-type="short">
            <p class="wf-parking-map__zone-title">Краткосрочная парковка</p>
            <p class="wf-parking-map__zone-meta">мест: 35 · свободно: [—]</p>
          </div>
          <div class="wf-parking-map__zone" data-zone-type="long">
            <p class="wf-parking-map__zone-title">Долгосрочная парковка ФЛ+ЮЛ</p>
            <p class="wf-parking-map__zone-meta">мест: 15 · свободно: [—]</p>
          </div>
          <div class="wf-parking-map__zone" data-zone-type="municipal">
            <p class="wf-parking-map__zone-title">Муниципальная техника + мотоциклы + резерв</p>
            <p class="wf-parking-map__zone-meta">мест: 50 · свободно: [—]</p>
          </div>
          <div class="wf-parking-map__zone" data-zone-type="short">
            <p class="wf-parking-map__zone-title">Краткосрочная парковка</p>
            <p class="wf-parking-map__zone-meta">мест: 45 · свободно: [—]</p>
          </div>
          <div class="wf-parking-map__zone" data-zone-type="ovz">
            <p class="wf-parking-map__zone-title">Места для лиц с ОВЗ</p>
            <p class="wf-parking-map__zone-meta">мест: 25 · свободно: [—]</p>
          </div>
        </div>
      </div>
      <div class="wf-parking-map__kpp">КПП юг</div>
      <div class="wf-parking-map__legend">
        <span>КПП — въезд/выезд</span>
        <span>Зона — тип и количество мест (свободно заполняется данными)</span>
        <p class="wf-parking-map__total">Всего мест по зонам: 600 (по Схеме парковки AS-IS)</p>
      </div>
    </div>
  </section>
{% endblock %}

