{% extends "layouts/admin.njk" %}

{% set current_nav = 'admin-tariffs' %}

{% block title %}Тарифы — ЛК админа{% endblock %}
{% block header_subtitle %}Управление тарифами{% endblock %}

{% block content %}
  <h2>Управление тарифами</h2>

  <section class="wf-section">
    <h3>Фильтры по тарифам</h3>
    <form class="wf-form sessions-filters">
      <div class="filters-row">
        <div class="wf-field">
          <label for="search-tariff-name">Название тарифа</label>
          <input id="search-tariff-name" type="text" placeholder="Например, Почасовой А">
        </div>
        <div class="wf-field">
          <label for="search-tariff-type">Тип тарифа</label>
          <select id="search-tariff-type">
            <option value="">Любой</option>
            <option value="contract">Договорный</option>
            <option value="hourly">Почасовой</option>
          </select>
        </div>
        <div class="wf-field">
          <label for="search-tariff-status">Статус</label>
          <select id="search-tariff-status">
            <option value="">Любой</option>
            <option value="active">Активен</option>
            <option value="archived">Архив</option>
          </select>
        </div>
        <div class="filter-actions">
          <button type="submit">Показать</button>
        </div>
      </div>
    </form>
  </section>

  <div class="wf-actions" style="margin-bottom: 1rem;">
    <a href="#admin-tariff-create-modal" class="wf-btn">Создать тариф</a>
  </div>

  <section class="wf-section">
    <h3>Реестр тарифов</h3>
    <p class="wf-muted">Тариф — набор правил расчёта стоимости. Ниже — примеры тарифов для прототипа.</p>
    <div class="wf-table-wrap">
      <table class="wf-table">
        <thead>
          <tr>
            <th>Название тарифа</th>
            <th>Тип</th>
            <th>Парковка / сектор</th>
            <th>Основные условия</th>
            <th>Статус</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Почасовой А</td>
            <td>Почасовой</td>
            <td>Основная парковка, сектор А</td>
            <td>Первые 15 минут бесплатно, далее поминутно</td>
            <td><span class="wf-badge">Активен</span></td>
            <td><a href="#admin-tariff-modal" class="wf-btn">Настроить</a></td>
          </tr>
          <tr>
            <td>Долгосрочная парковка, сектор Б</td>
            <td>Договорный</td>
            <td>Многоуровневая парковка, сектор Б</td>
            <td>Месячный платёж, фиксированное место</td>
            <td><span class="wf-badge">Активен</span></td>
            <td><a href="#admin-tariff-modal" class="wf-btn">Настроить</a></td>
          </tr>
          <tr>
            <td>Ночной тариф</td>
            <td>Почасовой</td>
            <td>Все секторы</td>
            <td>С 22:00 до 07:00, пониженная ставка</td>
            <td><span class="wf-badge">Архив</span></td>
            <td><a href="#admin-tariff-modal" class="wf-btn">Настроить</a></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section id="admin-tariff-modal" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="admin-tariff-title">
    <div class="wf-modal__dialog wf-modal__dialog--form">
      <header class="wf-modal__header">
        <h2 id="admin-tariff-title" class="wf-modal__title">Настройки тарифа</h2>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть">✕</a>
      </header>
      <div class="wf-modal__body">
        <form class="wf-form">
          <section class="wf-section">
            <h3>Основные параметры</h3>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-tariff-name">Название тарифа</label>
                <input id="admin-tariff-name" type="text" value="Почасовой А">
              </div>
              <div class="wf-field">
                <label for="admin-tariff-type-edit">Тип тарифа</label>
                <select id="admin-tariff-type-edit">
                  <option value="hourly" selected>Почасовой</option>
                  <option value="contract">Договорный</option>
                </select>
              </div>
            </div>
            <div class="wf-field">
              <label for="admin-tariff-sector">Сектор</label>
              <select id="admin-tariff-sector">
                <option value="A" selected>Сектор А</option>
                <option value="B">Сектор Б</option>
                <option value="C">Сектор В</option>
                <option value="all">Все секторы</option>
              </select>
            </div>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-tariff-hour-rate">Стоимость за час (₽)</label>
                <input id="admin-tariff-hour-rate" type="number" min="0" step="1" value="150">
              </div>
              <div class="wf-field">
                <label for="admin-tariff-grace">Грейс-период (минут)</label>
                <input id="admin-tariff-grace" type="number" min="0" max="120" value="15" placeholder="0">
              </div>
            </div>
          </section>

          <section class="wf-section">
            <h3>Условия применения тарифа</h3>
            <p class="wf-muted">Время действия — для тарифов по времени суток (например, ночной). Оставьте пустым для круглосуточного применения.</p>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-tariff-time-from">Действует с (время)</label>
                <input id="admin-tariff-time-from" type="time" value="" placeholder="00:00">
              </div>
              <div class="wf-field">
                <label for="admin-tariff-time-to">Действует по (время)</label>
                <input id="admin-tariff-time-to" type="time" value="" placeholder="23:59">
              </div>
            </div>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-tariff-min-hours">Мин. длительность парковки (часов)</label>
                <input id="admin-tariff-min-hours" type="number" min="0" step="0.5" value="" placeholder="Не ограничено">
              </div>
              <div class="wf-field">
                <label for="admin-tariff-max-hours">Макс. длительность парковки (часов)</label>
                <input id="admin-tariff-max-hours" type="number" min="0" step="0.5" value="" placeholder="Не ограничено">
              </div>
            </div>
            <div class="wf-field">
              <label>Дни недели</label>
              <div class="wf-checkbox-group">
                <label class="wf-checkbox"><input type="checkbox" name="admin-tariff-days" value="1" checked> Пн</label>
                <label class="wf-checkbox"><input type="checkbox" name="admin-tariff-days" value="2" checked> Вт</label>
                <label class="wf-checkbox"><input type="checkbox" name="admin-tariff-days" value="3" checked> Ср</label>
                <label class="wf-checkbox"><input type="checkbox" name="admin-tariff-days" value="4" checked> Чт</label>
                <label class="wf-checkbox"><input type="checkbox" name="admin-tariff-days" value="5" checked> Пт</label>
                <label class="wf-checkbox"><input type="checkbox" name="admin-tariff-days" value="6" checked> Сб</label>
                <label class="wf-checkbox"><input type="checkbox" name="admin-tariff-days" value="0" checked> Вс</label>
              </div>
            </div>
            <div class="wf-field">
              <label for="admin-tariff-conditions">Краткое описание условий (для отображения)</label>
              <textarea id="admin-tariff-conditions" rows="2" placeholder="Например: первые 15 минут бесплатно, далее поминутно.">Первые 15 минут бесплатно, далее поминутно.</textarea>
            </div>
            <div class="wf-field">
              <label for="admin-tariff-status-edit">Статус тарифа</label>
              <select id="admin-tariff-status-edit">
                <option value="active" selected>Активен</option>
                <option value="archived">Архив</option>
              </select>
            </div>
          </section>

          <div class="wf-actions">
            <button type="submit">Сохранить тариф</button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section id="admin-tariff-create-modal" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="admin-tariff-create-title">
    <div class="wf-modal__dialog wf-modal__dialog--form">
      <header class="wf-modal__header">
        <h2 id="admin-tariff-create-title" class="wf-modal__title">Создание тарифа</h2>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть">✕</a>
      </header>
      <div class="wf-modal__body">
        <form class="wf-form">
          <section class="wf-section">
            <h3>Основные параметры</h3>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-tariff-create-name">Название тарифа</label>
                <input id="admin-tariff-create-name" type="text" placeholder="Например, Почасовой В">
              </div>
              <div class="wf-field">
                <label for="admin-tariff-create-type">Тип тарифа</label>
                <select id="admin-tariff-create-type">
                  <option value="hourly">Почасовой</option>
                  <option value="contract">Договорный</option>
                </select>
              </div>
            </div>
            <div class="wf-field">
              <label for="admin-tariff-create-sector">Сектор</label>
              <select id="admin-tariff-create-sector">
                <option value="A">Сектор А</option>
                <option value="B">Сектор Б</option>
                <option value="C">Сектор В</option>
                <option value="all">Все секторы</option>
              </select>
            </div>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-tariff-create-hour-rate">Стоимость за час (₽)</label>
                <input id="admin-tariff-create-hour-rate" type="number" min="0" step="1" placeholder="0">
              </div>
              <div class="wf-field">
                <label for="admin-tariff-create-grace">Грейс-период (минут)</label>
                <input id="admin-tariff-create-grace" type="number" min="0" max="120" value="0" placeholder="0">
              </div>
            </div>
          </section>

          <section class="wf-section">
            <h3>Условия применения тарифа</h3>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-tariff-create-time-from">Действует с (время)</label>
                <input id="admin-tariff-create-time-from" type="time" placeholder="00:00">
              </div>
              <div class="wf-field">
                <label for="admin-tariff-create-time-to">Действует по (время)</label>
                <input id="admin-tariff-create-time-to" type="time" placeholder="23:59">
              </div>
            </div>
            <div class="wf-grid wf-grid--two">
              <div class="wf-field">
                <label for="admin-tariff-create-min-hours">Мин. длительность (часов)</label>
                <input id="admin-tariff-create-min-hours" type="number" min="0" step="0.5" placeholder="Не ограничено">
              </div>
              <div class="wf-field">
                <label for="admin-tariff-create-max-hours">Макс. длительность (часов)</label>
                <input id="admin-tariff-create-max-hours" type="number" min="0" step="0.5" placeholder="Не ограничено">
              </div>
            </div>
            <div class="wf-field">
              <label>Дни недели</label>
              <div class="wf-checkbox-group">
                <label class="wf-checkbox"><input type="checkbox" name="admin-tariff-create-days" value="1" checked> Пн</label>
                <label class="wf-checkbox"><input type="checkbox" name="admin-tariff-create-days" value="2" checked> Вт</label>
                <label class="wf-checkbox"><input type="checkbox" name="admin-tariff-create-days" value="3" checked> Ср</label>
                <label class="wf-checkbox"><input type="checkbox" name="admin-tariff-create-days" value="4" checked> Чт</label>
                <label class="wf-checkbox"><input type="checkbox" name="admin-tariff-create-days" value="5" checked> Пт</label>
                <label class="wf-checkbox"><input type="checkbox" name="admin-tariff-create-days" value="6" checked> Сб</label>
                <label class="wf-checkbox"><input type="checkbox" name="admin-tariff-create-days" value="0" checked> Вс</label>
              </div>
            </div>
            <div class="wf-field">
              <label for="admin-tariff-create-conditions">Краткое описание условий</label>
              <textarea id="admin-tariff-create-conditions" rows="2" placeholder="Например: первые 15 минут бесплатно, далее поминутно."></textarea>
            </div>
          </section>

          <div class="wf-actions">
            <button type="submit">Создать тариф</button>
          </div>
        </form>
      </div>
    </div>
  </section>
{% endblock %}
