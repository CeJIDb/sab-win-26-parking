{% extends "layouts/admin.njk" %}
{% block title %}История парковочных сессий — ЛК админа{% endblock %}
{% block content %}
  <div class="wf-page-head">
    <button type="button" class="wf-back">Назад</button>
    <h2>История сессий по номеру А123БВ777</h2>
  </div>
<p class="wf-muted">Статический пример страницы истории сессий для выбранного клиента и номера ТС. В реальной системе фильтры и данные заполняются автоматически по параметру запроса.</p>

<section class="wf-section">
  <h3>Фильтры по сессиям</h3>
  <form class="wf-form sessions-filters">
    <div class="filters-row">
      <div class="wf-field">
        <label for="client-sessions-from">С</label>
        <input id="client-sessions-from" type="date">
      </div>
      <div class="wf-field">
        <label for="client-sessions-to">По</label>
        <input id="client-sessions-to" type="date">
      </div>
      <div class="wf-field">
        <label for="client-sessions-kpp">КПП</label>
        <select id="client-sessions-kpp">
          <option value="">Любой</option>
          <option value="kpp1">КПП‑1</option>
          <option value="kpp2">КПП‑2</option>
        </select>
      </div>
      <div class="wf-field">
        <label for="client-sessions-status">Статус</label>
        <select id="client-sessions-status">
          <option value="">Любой</option>
          <option value="ok">Разрешено</option>
          <option value="denied">Отказано</option>
        </select>
      </div>
      <div class="filter-actions">
        <button type="submit">Показать</button>
      </div>
    </div>
  </form>
</section>

<section class="wf-section">
  <h3>Список сессий по номеру А123БВ777</h3>
  <div class="wf-table-wrap">
    <table class="wf-table">
      <thead>
        <tr>
          <th scope="col">Дата и время</th>
          <th scope="col">КПП</th>
          <th scope="col">ГРЗ</th>
          <th scope="col">Направление</th>
          <th scope="col">Статус</th>
          <th scope="col">Основание</th>
          <th scope="col">Комментарий</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>24.02.2026 10:15</td>
          <td>КПП‑1</td>
          <td>А123БВ777</td>
          <td>Въезд</td>
          <td>Разрешено</td>
          <td>Автоматически (по договору)</td>
          <td>Активный договор Д‑045, нет задолженности.</td>
        </tr>
        <tr>
          <td>23.02.2026 18:40</td>
          <td>КПП‑1</td>
          <td>А123БВ777</td>
          <td>Выезд</td>
          <td>Разрешено</td>
          <td>Автоматически (по сессии)</td>
          <td>Оплата сессии успешна.</td>
        </tr>
        <tr>
          <td>22.02.2026 09:05</td>
          <td>КПП‑2</td>
          <td>А123БВ777</td>
          <td>Въезд</td>
          <td>Отказ</td>
          <td>Охранник</td>
          <td>Несовпадение номера с бронированием, водитель направлен на стоянку ожидания.</td>
        </tr>
      </tbody>
    </table>
  </div>
</section>
{% endblock %}
