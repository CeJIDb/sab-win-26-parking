{% extends "layouts/lk.njk" %}

{% set current_nav = 'sessions-history' %}

{% block title %}История парковочных сессий — ЛК клиента{% endblock %}

{% block content %}
  <div class="wf-page-head">
    <button type="button" class="wf-back">Назад</button>
    <h2>История парковочных сессий</h2>
  </div>

  <section class="wf-section" aria-labelledby="sessions-active-heading">
    <h3 id="sessions-active-heading">Активные парковочные сессии</h3>
    <p class="wf-muted">Текущие сессии без выезда. Оплату можно произвести в разделе <a href="payment-settings.html">Оплаты</a> или на главной.</p>
    <div class="wf-table-wrap" role="region" aria-label="Активные сессии">
      <table class="wf-table">
        <thead>
          <tr>
            <th scope="col">ID сессии</th>
            <th scope="col">Дата въезда</th>
            <th scope="col">Тип сессии</th>
            <th scope="col">ТС (ГРЗ)</th>
            <th scope="col">ПМ / сектор</th>
            <th scope="col">К оплате</th>
            <th scope="col">Действия</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><a href="#" aria-label="Открыть детали сессии S-1045">S-1045</a></td>
            <td>24.02.2026 10:05</td>
            <td>Постоплата</td>
            <td>А123БВ777</td>
            <td>КПП‑1, краткосрочная</td>
            <td>350 ₽</td>
            <td><a href="payment-external.html" class="wf-btn">Оплатить</a></td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="wf-muted">Если активных сессий нет, таблица пуста. <strong>Тип сессии:</strong> постоплата — краткосрочные тарифы, оплата после выезда; бронирование — краткосрочные с предоплатой и резервом места; договор — долгосрочные по договору (оплата заранее).</p>
  </section>

  <section class="wf-section" aria-labelledby="sessions-history-heading">
    <h3 id="sessions-history-heading">История сессий</h3>
    <p class="wf-muted">Завершённые и отменённые парковочные сессии.</p>
    <form class="wf-form sessions-filters wf-filters" aria-label="Фильтры по истории сессий">
      <div class="filters-row">
        <div class="wf-field">
          <label for="filter-history-date-from">Период с</label>
          <input id="filter-history-date-from" type="date" aria-label="Дата начала периода">
        </div>
        <div class="wf-field">
          <label for="filter-history-date-to">по</label>
          <input id="filter-history-date-to" type="date" aria-label="Дата окончания периода">
        </div>
        <div class="wf-field">
          <label for="filter-history-grz">ГРЗ</label>
          <select id="filter-history-grz" aria-label="Выберите ТС">
            <option value="">Все ТС</option>
            <option value="А123БВ777">А123БВ777</option>
            <option value="В456ГД177">В456ГД177</option>
          </select>
        </div>
        <div class="wf-field">
          <label for="filter-history-type">Тип сессии</label>
          <select id="filter-history-type" aria-label="Тип сессии">
            <option value="">Все</option>
            <option value="postpay">Постоплата</option>
            <option value="booking">Бронирование</option>
            <option value="contract">Договор</option>
          </select>
        </div>
        <div class="filter-actions">
          <button type="button">Применить</button>
          <button type="button">Сброс</button>
        </div>
      </div>
    </form>
    <div class="wf-table-wrap" role="region" aria-label="История сессий">
      <table class="wf-table">
        <thead>
          <tr>
            <th scope="col">ID сессии</th>
            <th scope="col">Дата въезда</th>
            <th scope="col">Дата выезда</th>
            <th scope="col">Тип сессии</th>
            <th scope="col">Длительность</th>
            <th scope="col">ТС (ГРЗ)</th>
            <th scope="col">ПМ / сектор</th>
            <th scope="col">Сумма</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><a href="#" aria-label="Открыть детали сессии S-1001">S-1001</a></td>
            <td>20.02.2026 09:15</td>
            <td>20.02.2026 18:42</td>
            <td>Договор</td>
            <td>9 ч 27 мин</td>
            <td>А123БВ777</td>
            <td>Долгосрочная, сектор А</td>
            <td>—</td>
          </tr>
          <tr>
            <td><a href="#" aria-label="Открыть детали сессии S-0999">S-0999</a></td>
            <td>18.02.2026 14:00</td>
            <td>19.02.2026 08:30</td>
            <td>Постоплата</td>
            <td>18 ч 30 мин</td>
            <td>В456ГД177</td>
            <td>Краткосрочная, ОВЗ</td>
            <td>320 ₽</td>
          </tr>
          <tr>
            <td><a href="#" aria-label="Открыть детали сессии S-0995">S-0995</a></td>
            <td>15.02.2026 07:50</td>
            <td>17.02.2026 07:50</td>
            <td>Договор</td>
            <td>2 д 0 ч</td>
            <td>А123БВ777</td>
            <td>Долгосрочная, сектор Б</td>
            <td>—</td>
          </tr>
          <tr>
            <td><a href="#" aria-label="Открыть детали сессии S-0988">S-0988</a></td>
            <td>10.02.2026 16:20</td>
            <td>10.02.2026 19:45</td>
            <td>Бронирование</td>
            <td>3 ч 25 мин</td>
            <td>В456ГД177</td>
            <td>Краткосрочная</td>
            <td>—</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="wf-muted">Сумма указывается только для сессий по постоплате (краткосрочные тарифы). Для бронирования и договора оплата произведена заранее. [Пагинация.]</p>
  </section>
{% endblock %}
