{% extends "layouts/lk.njk" %}

{% set current_nav = 'sessions-history' %}

{% block title %}История парковочных сессий — ЛК клиента{% endblock %}
{% block header_subtitle %}История парковочных сессий{% endblock %}

{% block content %}
  <h2>История парковочных сессий</h2>
  <section class="wf-section">
    <div class="sessions-filters" aria-label="Фильтры">
      <div class="filters-row">
        <div class="wf-field">
          <label for="filter-date-from">С</label>
          <input id="filter-date-from" type="date" aria-label="Дата начала периода">
        </div>
        <div class="wf-field">
          <label for="filter-date-to">По</label>
          <input id="filter-date-to" type="date" aria-label="Дата окончания периода">
        </div>
        <div class="wf-field">
          <label for="filter-grz">ГРЗ</label>
          <select id="filter-grz" aria-label="Выберите ТС из добавленных">
            <option value="">Все ТС</option>
            <option value="А123БВ777">А123БВ777</option>
            <option value="В456ГД177">В456ГД177</option>
          </select>
        </div>
        <div class="filter-actions">
          <button type="button">Применить</button>
          <button type="button">Сброс</button>
        </div>
      </div>
    </div>
    <p>Парковочная сессия — период от въезда до выезда, по которому начисляется плата (Концептуальная модель).</p>
    <div class="wf-table-wrap">
      <table class="wf-table">
        <thead>
          <tr>
            <th>ID сессии</th>
            <th>Дата въезда</th>
            <th>Дата выезда</th>
            <th>Длительность</th>
            <th>ТС (ГРЗ)</th>
            <th>ПМ / сектор</th>
            <th>Сумма / платёж</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><a href="#" aria-label="Открыть детали сессии S-1001">S-1001</a></td>
            <td>20.02.2026 09:15</td>
            <td>20.02.2026 18:42</td>
            <td>9 ч 27 мин</td>
            <td>А123БВ777</td>
            <td>Долгосрочная, сектор А</td>
            <td>450 ₽</td>
          </tr>
          <tr>
            <td><a href="#" aria-label="Открыть детали сессии S-0999">S-0999</a></td>
            <td>18.02.2026 14:00</td>
            <td>19.02.2026 08:30</td>
            <td>18 ч 30 мин</td>
            <td>В456ГД177</td>
            <td>Краткосрочная, ОВЗ</td>
            <td>320 ₽</td>
          </tr>
          <tr>
            <td><a href="#" aria-label="Открыть детали сессии S-0995">S-0995</a></td>
