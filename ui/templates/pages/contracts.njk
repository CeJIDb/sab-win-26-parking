{% extends "layouts/lk.njk" %}

{% set current_nav = 'contracts' %}

{% block title %}Договоры — ЛК клиента{% endblock %}
{% block header_subtitle %}Управление договорами{% endblock %}

{% block content %}
  <h2>Управление договорами</h2>

  <section class="wf-section">
    <h3>Мои договоры</h3>
    <div class="wf-actions">
      <a href="contracts-create.html" class="wf-btn">Создать договор</a>
    </div>
    <form class="wf-form sessions-filters" aria-label="Фильтры по договорам">
      <div class="filters-row">
        <div class="wf-field">
          <label for="filter-contract-number">Номер договора</label>
          <input id="filter-contract-number" type="text" placeholder="Например, 1001">
        </div>
        <div class="wf-field">
          <label for="filter-contract-status">Статус</label>
          <select id="filter-contract-status">
            <option value="">Все статусы</option>
            <option value="active">Активен</option>
            <option value="pending">На оформлении</option>
            <option value="closed">Завершён</option>
          </select>
        </div>
        <div class="wf-field">
          <label for="filter-contract-debt">Наличие задолженности</label>
          <select id="filter-contract-debt">
            <option value="">Не учитывать</option>
            <option value="no-debt">Без задолженности</option>
            <option value="has-debt">Есть задолженность</option>
          </select>
        </div>
        <div class="filter-actions">
          <button type="button">Применить</button>
          <button type="button">Сбросить</button>
        </div>
      </div>
    </form>
    <div class="wf-table-wrap" role="region" aria-label="Список договоров">
      <table class="wf-table">
        <thead>
          <tr>
            <th scope="col">Договор</th>
            <th scope="col">Период</th>
            <th scope="col">Статус</th>
            <th scope="col">ТС / ПМ</th>
            <th scope="col">Задолженность</th>
            <th scope="col">Документ</th>
            <th scope="col">Действия</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>№1001</td>
            <td>01.01.2026–31.12.2026</td>
            <td>Активен</td>
            <td>2 ТС, 2 ПМ</td>
            <td>Нет</td>
            <td><a href="#" class="wf-btn">Скачать</a></td>
            <td>
              <a href="#contract-edit-modal" class="wf-btn">Изменить</a>
              <a href="#contract-terminate-modal" class="wf-btn wf-btn-secondary">Расторгнуть</a>
            </td>
          </tr>
          <tr>
            <td>№1002</td>
            <td>15.02.2026–14.05.2026</td>
            <td>Активен</td>
            <td>1 ТС, 1 ПМ</td>
            <td>Есть 1 просроченный платёж</td>
            <td><a href="#" class="wf-btn">Скачать</a></td>
            <td>
              <a href="#contract-edit-modal" class="wf-btn">Изменить</a>
              <a href="#contract-terminate-modal" class="wf-btn wf-btn-secondary">Расторгнуть</a>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section id="contract-edit-modal" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="contract-edit-title">
    <div class="wf-modal__dialog wf-section">
      <header class="wf-modal__header">
        <h3 id="contract-edit-title">Изменение договора №1001</h3>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть окно">✕</a>
      </header>
      <form class="wf-form">
        <p class="wf-notice"><strong>Продление договора.</strong> Текущая дата окончания: 31.12.2026.</p>
        <div class="wf-field wf-field--inline-control">
          <label for="contract-extend-to">Новая дата окончания</label>
          <div class="wf-inline">
            <input id="contract-extend-to" type="date" aria-label="Новая дата окончания договора">
          </div>
        </div>
        <div class="wf-field wf-field--inline-control">
          <label>ТС (ГРЗ) по договору</label>
          <div class="wf-inline">
            <select id="contract-edit-vehicle-picker">
              <option value="">— выбрать ТС —</option>
              <option value="A123BV777">А123БВ777 — Toyota Camry</option>
              <option value="V456GD177">В456ГД177 — Honda Civic</option>
              <option value="X999YY199">X999YY199 — Пример дополнительного ТС</option>
            </select>
            <button type="button" aria-label="Добавить ТС по договору">Добавить</button>
          </div>
          <ul class="wf-list wf-list--compact" id="contract-edit-vehicle-list">
            <li>А123БВ777 — Toyota Camry <button type="button" aria-label="Удалить ТС из договора">−</button></li>
            <li>В456ГД177 — Honda Civic <button type="button" aria-label="Удалить ТС из договора">−</button></li>
          </ul>
        </div>
        <div class="wf-field wf-field--inline-control">
          <label>Парковочные места (ПМ)</label>
          <div class="wf-inline">
            <select id="contract-edit-place-picker">
              <option value="">— выбрать ПМ —</option>
              <option value="A-101">ПМ 101 — сектор А</option>
              <option value="A-102">ПМ 102 — сектор А</option>
              <option value="B-201">ПМ 201 — сектор Б</option>
            </select>
            <button type="button" aria-label="Добавить ПМ по договору">Добавить</button>
          </div>
          <ul class="wf-list wf-list--compact" id="contract-edit-place-list">
            <li>ПМ 101 — сектор А <button type="button" aria-label="Удалить ПМ из договора">−</button></li>
            <li>ПМ 102 — сектор А <button type="button" aria-label="Удалить ПМ из договора">−</button></li>
          </ul>
        </div>
        <div class="wf-card">
          <p><strong>Перерасчёт стоимости договора</strong></p>
          <p class="wf-muted">Итоговая стоимость и возможная доплата/возврат будут пересчитаны автоматически с учётом нового срока действия, состава ТС и парковочных мест. Здесь в дальнейшем будет выводиться сумма к оплате.</p>
        </div>
        <div class="wf-actions">
          <button type="submit">Сохранить изменения</button>
        </div>
      </form>
    </div>
  </section>
  <section id="contract-terminate-modal" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="contract-terminate-title">
    <div class="wf-modal__dialog wf-section">
      <header class="wf-modal__header">
        <h3 id="contract-terminate-title">Расторжение договора №1001</h3>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть окно">✕</a>
      </header>
      <form class="wf-form">
        <p class="wf-notice">
          <strong>Юридически значимое действие.</strong> Фактическое расторжение договора выполняется управляющей компанией на основании поданной заявки.
        </p>
        <div class="wf-card">
          <p><strong>Что произойдёт после отправки заявки</strong></p>
          <p class="wf-muted">
            Заявка на расторжение будет передана управляющему парковкой. После проверки задолженности и отсутствия активных бронирований/парковочных сессий договор будет расторгнут, доступ на парковку по данному договору будет прекращён, а излишне уплаченные суммы (при наличии) могут быть возвращены согласно условиям договора.
          </p>
        </div>
        <div class="wf-field">
          <label for="contract-terminate-reason">Причина расторжения</label>
          <textarea id="contract-terminate-reason" rows="3" placeholder="Кратко опишите причину расторжения договора (например, смена ТС, прекращение пользования парковкой)"></textarea>
        </div>
        <div class="wf-checkbox-group">
          <label class="wf-checkbox">
            <input type="checkbox" required>
            Подтверждаю, что ознакомлен(а) с условиями расторжения и прошу направить заявку управляющему
          </label>
        </div>
        <div class="wf-actions">
          <button type="submit">Отправить заявку на расторжение</button>
        </div>
      </form>
    </div>
  </section>
{% endblock %}
