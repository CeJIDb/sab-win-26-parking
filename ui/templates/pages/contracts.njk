{% extends "layouts/client.njk" %}

{% set current_nav = 'payment-settings' %}

{% block header_breadcrumbs %}<span class="wf-breadcrumbs__current">Договоры</span>{% endblock %}
{% block title %}Договоры — ЛК клиента{% endblock %}

{% block content %}
  <div class="wf-page-head">
    <button type="button" class="wf-back">Назад</button>
    <h2>Управление договорами</h2>
  </div>

  <section class="wf-section" aria-labelledby="contracts-active-heading">
    <h3 id="contracts-active-heading">Активные договоры</h3>
    <div class="wf-actions">
      <a href="contracts-create.html" class="wf-btn">Создать договор</a>
    </div>
    <p class="wf-muted">Действующие договоры и договоры на оформлении. Завершённые и расторгнутые — в блоке «История договоров» ниже.</p>
    <div class="wf-table-wrap" role="region" aria-label="Активные договоры">
      <table class="wf-table">
        <thead>
          <tr>
            <th scope="col">Договор</th>
            <th scope="col">Период</th>
            <th scope="col">Статус</th>
            <th scope="col">ТС / ПМ</th>
            <th scope="col">Задолженность</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><a href="#client-modal-contract-view">Д-1001</a></td>
            <td>01.01.2026–31.12.2026</td>
            <td>Активен</td>
            <td>2 ТС, 2 ПМ</td>
            <td>Нет</td>
          </tr>
          <tr>
            <td><a href="#client-modal-contract-view">Д-1002</a></td>
            <td>15.02.2026–14.05.2026</td>
            <td>Активен</td>
            <td>1 ТС, 1 ПМ</td>
            <td>Есть 1 просроченный платёж — <a href="payment-external.html">Оплатить</a></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="wf-section" aria-labelledby="contracts-history-heading">
    <h3 id="contracts-history-heading">История договоров</h3>
    <p class="wf-muted">Завершённые и расторгнутые договоры.</p>
    <form class="wf-form wf-filters" aria-label="Фильтры по истории договоров">
      <div class="filters-row">
        <div class="wf-field">
          <label for="filter-history-contract-number">Номер договора</label>
          <input id="filter-history-contract-number" type="text" placeholder="Например, Д-0999">
        </div>
        <div class="wf-field">
          <label for="filter-history-contract-status">Статус</label>
          <select id="filter-history-contract-status" aria-label="Статус в истории">
            <option value="">Все</option>
            <option value="closed">Завершён</option>
            <option value="terminated">Расторгнут</option>
          </select>
        </div>
        <div class="wf-field">
          <label for="filter-history-contract-date-from">Период с</label>
          <input id="filter-history-contract-date-from" type="date" aria-label="Дата начала периода действия">
        </div>
        <div class="wf-field">
          <label for="filter-history-contract-date-to">по</label>
          <input id="filter-history-contract-date-to" type="date" aria-label="Дата окончания периода">
        </div>
        <div class="filter-actions">
          <button type="button">Применить</button>
          <button type="button">Сбросить</button>
        </div>
      </div>
    </form>
    <div class="wf-table-wrap" role="region" aria-label="История договоров">
      <table class="wf-table">
        <thead>
          <tr>
            <th scope="col">Договор</th>
            <th scope="col">Период</th>
            <th scope="col">Статус</th>
            <th scope="col">ТС / ПМ</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><a href="#client-modal-contract-view" aria-label="Открыть договор Д-0999">Д-0999</a></td>
            <td>01.06.2025–31.12.2025</td>
            <td><span class="wf-badge">Завершён</span></td>
            <td>1 ТС, 1 ПМ</td>
          </tr>
          <tr>
            <td><a href="#client-modal-contract-view" aria-label="Открыть договор Д-0998">Д-0998</a></td>
            <td>01.03.2025–15.05.2025</td>
            <td><span class="wf-badge">Расторгнут</span></td>
            <td>1 ТС, 1 ПМ</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  {% include "partials/client-contract-view-modal.njk" %}
  {% include "partials/contract-edit-modal.njk" %}
  {% include "partials/contract-terminate-modal.njk" %}
{% endblock %}
