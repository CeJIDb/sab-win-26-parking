{% extends "layouts/lk.njk" %}

{% set current_nav = 'bookings' %}

{% block title %}Управление бронированием — ЛК клиента{% endblock %}

{% block content %}
  <div class="wf-page-head">
    <button type="button" class="wf-back">Назад</button>
    <h2>Управление бронированием</h2>
  </div>
  <p class="wf-error" role="alert" aria-live="polite" aria-hidden="true"></p>

  <section class="wf-section" aria-labelledby="bookings-active-heading">
    <h3 id="bookings-active-heading">Активные бронирования</h3>
    <div class="wf-actions">
      <a href="#booking-create-modal" class="wf-btn">Создать бронирование</a>
    </div>
    <p class="wf-muted">Подтверждённые и ожидающие оплаты бронирования. Завершённые и отменённые — в блоке «История бронирований» ниже.</p>
    <div class="wf-table-wrap" role="region" aria-label="Активные бронирования">
      <table class="wf-table">
        <thead>
          <tr>
            <th scope="col">Бронирование</th>
            <th scope="col">Период</th>
            <th scope="col">Сектор / ПМ</th>
            <th scope="col">Тариф</th>
            <th scope="col">Сумма</th>
            <th scope="col">Статус</th>
            <th scope="col">Действия</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>#1</td>
            <td>27.02.2026 19:00–22:00</td>
            <td>Сектор A</td>
            <td>Почасовой A</td>
            <td>—</td>
            <td><span class="wf-badge">Подтверждена</span></td>
            <td>
              <a href="#booking-edit-modal" class="wf-btn">Изменить</a>
              <a href="#booking-cancel-modal" class="wf-btn">Отменить</a>
            </td>
          </tr>
          <tr>
            <td>#2</td>
            <td>28.02.2026 08:00–10:00</td>
            <td>Сектор B</td>
            <td>Почасовой B</td>
            <td>450 ₽</td>
            <td><span class="wf-badge">Ожидает оплаты</span> — <a href="payment-external.html">Оплатить</a></td>
            <td>
              <a href="#booking-edit-modal" class="wf-btn">Изменить</a>
              <a href="#booking-cancel-modal" class="wf-btn">Отменить</a>
            </td>
          </tr>
          <tr>
            <td>#4</td>
            <td>01.02.2026–28.02.2026 (договор)</td>
            <td>Сектор Б, ПМ 201</td>
            <td>Долгосрочная (договор Д‑045)</td>
            <td>—</td>
            <td><span class="wf-badge">Подтверждена</span></td>
            <td>
              <a href="#contract-edit-modal" class="wf-btn">Изменить</a>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="wf-section" aria-labelledby="bookings-history-heading">
    <h3 id="bookings-history-heading">История бронирований</h3>
    <p class="wf-muted">Завершённые, отменённые и просроченные бронирования.</p>
    <form class="wf-form bookings-filters wf-filters" aria-label="Фильтры по истории бронирований">
      <div class="filters-row">
        <div class="wf-field">
          <label for="filter-history-booking-date-from">Период с</label>
          <input id="filter-history-booking-date-from" type="date" aria-label="Дата начала периода">
        </div>
        <div class="wf-field">
          <label for="filter-history-booking-date-to">по</label>
          <input id="filter-history-booking-date-to" type="date" aria-label="Дата окончания периода">
        </div>
        <div class="wf-field">
          <label for="filter-history-booking-search">Номер / дата брони</label>
          <input id="filter-history-booking-search" type="text" placeholder="Например, #3 или 26.02.2026">
        </div>
        <div class="wf-field">
          <label for="filter-history-booking-status">Статус</label>
          <select id="filter-history-booking-status" aria-label="Статус в истории">
            <option value="">Все</option>
            <option value="completed">Завершена</option>
            <option value="cancelled">Отменена</option>
          </select>
        </div>
        <div class="filter-actions">
          <button type="button">Применить</button>
          <button type="button">Сброс</button>
        </div>
      </div>
    </form>
    <div class="wf-table-wrap" role="region" aria-label="История бронирований">
      <table class="wf-table">
        <thead>
          <tr>
            <th scope="col">Бронирование</th>
            <th scope="col">Период</th>
            <th scope="col">Сектор / ПМ</th>
            <th scope="col">Тариф</th>
            <th scope="col">Сумма</th>
            <th scope="col">Статус</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>#3</td>
            <td>26.02.2026 20:00–23:00</td>
            <td>Сектор C</td>
            <td>Почасовой C</td>
            <td>320 ₽</td>
            <td><span class="wf-badge">Завершена</span></td>
          </tr>
          <tr>
            <td>#5</td>
            <td>15.02.2026 09:00–12:00</td>
            <td>Сектор A</td>
            <td>Почасовой A</td>
            <td>—</td>
            <td><span class="wf-badge">Отменена</span></td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="wf-muted">Для почасовых бронирований в истории указана оплаченная сумма. Для отменённых сумма не применяется (—). По договору — оплата по договору, в блоке активных «Сумма» только при статусе «Ожидает оплаты».</p>
  </section>

  {% include "partials/booking-create-modal.njk" %}
  {% include "partials/booking-edit-modal.njk" %}
  {% include "partials/booking-cancel-modal.njk" %}
  {% include "partials/contract-edit-modal.njk" %}
{% endblock %}
