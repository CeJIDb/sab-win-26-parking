{% extends "layouts/lk.njk" %}

{% set current_nav = 'profile' %}

{% block title %}Профиль — ЛК клиента{% endblock %}

{% block content %}
  <div class="wf-page-head">
    <button type="button" class="wf-back">Назад</button>
    <h2>Профиль</h2>
  </div>

  <section class="wf-section" aria-labelledby="profile-data-heading">
    <h3 id="profile-data-heading">Данные и настройки</h3>
    <div class="wf-grid wf-grid--two">
      <div class="wf-card">
        <p><strong>Телефон:</strong> +7 900 123-45-67</p>
        <p><strong>E-mail:</strong> ivanov@example.com</p>
        <p><strong>ФИО:</strong> Иванов Иван Иванович</p>
      </div>
      <div class="wf-card">
        <p><strong>Паспортные данные:</strong> <span class="wf-badge">Добавлены</span></p>
        <p><strong>Категория:</strong> Льготная (ОВЗ)</p>
      </div>
    </div>
    <div class="wf-actions">
      <a href="#profile-edit-modal" class="wf-btn">Изменить данные</a>
      <a href="#password-change-modal" class="wf-btn">Изменить пароль</a>
      <a href="#profile-settings-modal" class="wf-btn">Настройки</a>
      <a href="#profile-vehicles-modal" class="wf-btn">Список ТС</a>
    </div>
  </section>

  <section class="wf-section" aria-labelledby="profile-support-heading">
    <h3 id="profile-support-heading">Поддержка</h3>
    <div class="wf-actions">
      <a href="#profile-appeals-modal" class="wf-btn">Мои обращения</a>
      <a href="#appeal-create-modal" class="wf-btn">Написать в поддержку</a>
      <a href="tel:+78001234567" class="wf-btn">Позвонить в поддержку</a>
      <a href="../site/index.html#faq" class="wf-btn">FAQ</a>
    </div>
  </section>

  <section class="wf-section wf-section--logout">
    <a href="../site/login.html" class="wf-btn wf-btn-secondary">Выйти</a>
  </section>

  {% include "partials/profile-edit-modal.njk" %}
  {% include "partials/profile-passport-confirm-modal.njk" %}
  {% include "partials/profile-phone-modal.njk" %}
  {% include "partials/profile-email-modal.njk" %}
  {% include "partials/profile-password-modal.njk" %}
  {% include "partials/profile-passport-modal.njk" %}
  {% include "partials/profile-settings-modal.njk" %}
  {% include "partials/profile-vehicles-modal.njk" %}
  {% include "partials/profile-appeals-modal.njk" %}
  {% include "partials/appeal-details-modal.njk" %}
  {% include "partials/vehicles-add-modal.njk" %}
  {% include "partials/vehicles-edit-modal.njk" %}
  {% include "partials/vehicles-delete-modal.njk" %}
  {% include "partials/appeal-create-modal.njk" %}
{% endblock %}
