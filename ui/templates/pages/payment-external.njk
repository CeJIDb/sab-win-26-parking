{% extends "layouts/client.njk" %}

{% block title %}Оплата через платёжный сервис — ЛК клиента{% endblock %}
{% block header_breadcrumbs %}<a href="payment-settings.html">Оплаты</a><span class="wf-breadcrumbs__sep">/</span><span class="wf-breadcrumbs__current">Оплата</span>{% endblock %}

{% block content %}
  <div class="wf-page-head">
    <button type="button" class="wf-back">Назад</button>
    <h2>Оплата счёта</h2>
  </div>
  <p class="wf-muted">
    Для оплаты мы перенаправим вас во внешний платёжный сервис партнёра.
    После успешной оплаты статус счёта и история платежей обновятся в личном кабинете автоматически.
  </p>
  <section class="wf-section">
    <h3>Пример информации о счёте</h3>
    <div class="wf-card">
      <p><strong>Номер счёта:</strong> INV‑2026‑0001</p>
      <p><strong>Описание:</strong> Оплата по договору Д-1001 за март 2026</p>
      <p><strong>Сумма к оплате:</strong> 4 500 ₽</p>
    </div>
    <p class="wf-muted">
      На реальной интеграции здесь будет логотип и описание платёжного сервиса (например, «Оплата
      через платёжный шлюз банка/агрегатора»), а также юридически значимая информация о приёме платежей.
    </p>
    <div class="wf-actions">
      <a href="#" class="wf-btn">Перейти к оплате во внешнем сервисе</a>
      <a href="payment-settings.html" class="wf-btn wf-btn-secondary">Вернуться к списку счетов</a>
    </div>
  </section>
{% endblock %}

