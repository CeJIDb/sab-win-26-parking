{% extends "layouts/lk.njk" %}

{% set current_nav = 'appeals' %}

{% block title %}Обращения — ЛК клиента{% endblock %}
{% block header_subtitle %}Обращения в службу поддержки{% endblock %}

{% block content %}
  <!-- Основано на сущности Обращение и связях с Бронирование/Парковочная сессия/Платёж/Чек (Концептуальная модель) -->
  <h2>Обращения</h2>

  <section class="wf-section">
    <h3>Мои обращения</h3>
    <p class="wf-muted">Здесь отображаются ваши запросы в службу поддержки, связанные с бронированиями, договорами, сессиями и оплатами.</p>

    <div class="wf-actions">
      <a href="#appeal-create-modal" class="wf-btn wf-btn--primary">Создать обращение</a>
    </div>

    <ul class="wf-list wf-list--compact wf-appeals-list">
      <li class="wf-appeals-list__item">
        <span class="wf-appeals-list__main">
          <strong>#AP-001</strong> — Проблема с въездом на парковку
          <span class="wf-badge wf-badge--new">Новый</span>
        </span>
        <span class="wf-muted">Обновлено: 24.02.2026</span>
        <a href="#appeal-details-modal" class="wf-btn">Просмотреть</a>
      </li>
      <li class="wf-appeals-list__item">
        <span class="wf-appeals-list__main">
          <strong>#AP-002</strong> — Вопрос по автосписанию по договору
          <span class="wf-badge wf-badge--in-progress">В работе</span>
        </span>
        <span class="wf-muted">Обновлено: 23.02.2026</span>
        <a href="#appeal-details-modal" class="wf-btn">Просмотреть</a>
      </li>
      <li class="wf-appeals-list__item">
        <span class="wf-appeals-list__main">
          <strong>#AP-003</strong> — Уточнение по истории парковочной сессии
          <span class="wf-badge wf-badge--closed">Закрыто</span>
        </span>
        <span class="wf-muted">Обновлено: 20.02.2026</span>
        <a href="#appeal-details-modal" class="wf-btn">Просмотреть</a>
      </li>
    </ul>
  </section>

  {% include "partials/appeal-create-modal.njk" %}
  {% include "partials/appeal-details-modal.njk" %}
{% endblock %}

