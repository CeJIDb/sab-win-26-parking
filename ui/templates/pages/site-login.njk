{% extends "layouts/site.njk" %}

{% block title %}Вход — Цифровая платформа парковки{% endblock %}

{% block content %}
  <section class="wf-section" aria-labelledby="login-heading">
    <h2 id="login-heading">Вход в личный кабинет клиента</h2>
    <p class="wf-error" role="alert" aria-live="polite" aria-hidden="true"></p>
    <form class="wf-form" action="../client/dashboard.html" method="get">
      <div class="wf-field">
        <label for="login-username">Логин (телефон или e-mail)</label>
        <input id="login-username" type="text" placeholder="Телефон или e-mail" required>
      </div>
      <div class="wf-field">
        <label for="login-password">Пароль</label>
        <input id="login-password" type="password" placeholder="Пароль" required>
      </div>
      <div class="wf-actions">
        <button type="submit" class="wf-btn">Войти</button>
        <a href="register.html" class="wf-btn wf-btn-secondary">Регистрация</a>
        <a href="#restore-access-modal" class="wf-btn wf-btn-secondary">Забыли пароль?</a>
      </div>
    </form>
  </section>

  <section id="restore-access-modal" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="restore-access-title">
    <div class="wf-modal__dialog wf-section">
      <header class="wf-modal__header">
        <h3 id="restore-access-title">Восстановление доступа</h3>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть окно">✕</a>
      </header>
      <form class="wf-form">
        <p class="wf-muted">Укажите телефон или e-mail, которые вы использовали при регистрации. Мы отправим ссылку или код для восстановления доступа.</p>
        <div class="wf-field">
          <label for="restore-contact">Телефон или e-mail</label>
          <input id="restore-contact" type="text" placeholder="Телефон или e-mail из профиля" required>
        </div>
        <div class="wf-field wf-field--checkbox">
          <label for="restore-via-sms">
            <input id="restore-via-sms" type="checkbox" checked>
            Получить код по СМС
          </label>
        </div>
        <div class="wf-field wf-field--checkbox">
          <label for="restore-via-email">
            <input id="restore-via-email" type="checkbox">
            Получить ссылку на e-mail
          </label>
        </div>
        <p class="wf-muted">Если у вас нет доступа к указанным контактам, обратитесь в службу поддержки парковки.</p>
        <div class="wf-actions">
          <button type="submit">Отправить инструкцию по восстановлению</button>
        </div>
      </form>
    </div>
  </section>

  <section class="wf-section" aria-labelledby="login-sso-heading">
    <h3 id="login-sso-heading">Вход через SSO</h3>
    <p class="wf-muted">Яндекс ID / VK ID / MAX — по карте навигации.</p>
    <p class="wf-actions"><button type="button" class="wf-btn wf-btn-secondary">Яндекс ID</button> <button type="button" class="wf-btn wf-btn-secondary">VK ID</button> <button type="button" class="wf-btn wf-btn-secondary">MAX</button></p>
  </section>
{% endblock %}

