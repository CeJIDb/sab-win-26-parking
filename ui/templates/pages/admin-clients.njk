{% extends "layouts/admin.njk" %}
{% set current_nav = 'admin-clients' %}
{% block title %}Профили клиентов — ЛК админа{% endblock %}
{% block content %}
  <div class="wf-page-head">
    <button type="button" class="wf-back">Назад</button>
    <h2>Управление профилями клиентов</h2>
  </div>

<section class="wf-section">
  <h3>Реестр клиентов</h3>
  <div class="wf-actions">
    <a href="../site/register.html" class="wf-btn">Создать профиль</a>
  </div>
  <form class="wf-form sessions-filters" aria-label="Фильтр по клиентам">
    <div class="filters-row">
      <div class="wf-field">
        <label for="search-client-text">ФИО / телефон / e-mail</label>
        <input id="search-client-text" type="text" placeholder="Например, Иванов или +7…">
      </div>
      <div class="wf-field">
        <label for="search-client-access">Статус доступа</label>
        <select id="search-client-access">
          <option value="">Любой</option>
          <option value="allowed">Разрешён</option>
          <option value="limited">Ограничен</option>
          <option value="blocked">Заблокирован</option>
        </select>
      </div>
      <div class="wf-field">
        <label for="search-client-debt">Задолженность</label>
        <select id="search-client-debt">
          <option value="">Любая</option>
          <option value="no-debt">Нет задолженности</option>
          <option value="has-debt">Есть задолженность</option>
        </select>
      </div>
      <div class="filter-actions">
        <button type="submit">Применить</button>
        <button type="button">Сброс</button>
      </div>
    </div>
  </form>
  <div class="wf-table-wrap">
    <table class="wf-table">
      <thead>
        <tr>
          <th scope="col">Клиент</th>
          <th scope="col">Контакты</th>
          <th scope="col">Статус доступа</th>
          <th scope="col">Задолженность</th>
          <th scope="col">ТС</th>
          <th scope="col">Активные договоры</th>
          <th scope="col">Действия</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Иванов Иван Иванович</td>
          <td>+7 (900) 123‑45‑67<br>ivanov@example.com</td>
          <td><span class="wf-badge">Разрешён</span></td>
          <td>Нет</td>
          <td>2 ТС</td>
          <td>1 активный</td>
          <td><a href="#admin-client-fl-modal" class="wf-btn">Карточка клиента</a></td>
        </tr>
        <tr>
          <td>ООО «Ромашка»</td>
          <td>+7 (812) 555‑55‑55<br>office@romashka.ru</td>
          <td><span class="wf-badge">Ограничен</span></td>
          <td>Просрочка 3 дня</td>
          <td>5 ТС</td>
          <td>2 активных</td>
          <td><a href="#admin-client-yl-modal" class="wf-btn">Карточка клиента</a></td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

{% include "partials/admin-client-modal.njk" %}
{% endblock %}
