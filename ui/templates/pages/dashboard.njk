{% extends "layouts/lk.njk" %}

{% set current_nav = 'dashboard' %}

{% block title %}Личный кабинет клиента — Цифровая платформа парковки{% endblock %}
{% block header_subtitle %}Consumer App — вход после авторизации клиента{% endblock %}

{% block content %}
  <h2>Главная страница ЛК</h2>
  <section class="wf-section">
    <h3>Быстрые действия</h3>
    <div class="wf-grid wf-grid--three">
      <section class="wf-card">
        <h4>Парковочная сессия</h4>
        <p><strong>Активная сессия:</strong> S‑1045, КПП‑1, с 24.02.2026 10:05.</p>
        <p class="wf-muted">Ориентировочная сумма к оплате: 350 ₽ по тарифу «Почасовой А».</p>
        <p><a href="payment-external.html" class="wf-btn">Оплатить</a></p>
      </section>
      <section class="wf-card">
        <h4>Бронирование</h4>
        <p><strong>Планируемое бронирование:</strong> сегодня 19:00–22:00, сектор Б, место 203.</p>
        <p class="wf-muted">Рекомендуем создать или скорректировать бронирование заранее.</p>
        <p>
          <a href="bookings.html#booking-create-modal" class="wf-btn">Создать</a>
        </p>
      </section>
      <section class="wf-card">
        <h4>Договор</h4>
        <p><strong>Договор Д‑045:</strong> долг 1 200 ₽, срок оплаты до 01.03.2026.</p>
        <p class="wf-muted">Оплатите договор, чтобы избежать ограничений доступа на парковку.</p>
        <p><a href="payment-external.html" class="wf-btn">Оплатить</a></p>
      </section>
    </div>
  </section>
  <section class="wf-section">
    <h3>Количество свободных парковочных мест (карта по секторам)</h3>
    <p class="wf-muted">Схема парковки AS-IS: КПП север/юг, зоны по типам. Всего 600 мест.</p>
    <!-- Та же схема, что на сайте — по Схема парковки AS-IS.md -->
    <div class="wf-parking-map wf-parking-map--compact" role="img" aria-label="Схема парковки (компактно)">
      <div class="wf-parking-map__kpp">КПП север</div>
      <div class="wf-parking-map__zones">
        <div class="wf-parking-map__column">
          <div class="wf-parking-map__zone"><p class="wf-parking-map__zone-title">ОВЗ — 25</p><p class="wf-parking-map__zone-meta">свободно: 8 · занято: 17</p></div>
          <div class="wf-parking-map__zone"><p class="wf-parking-map__zone-title">Краткосрочная — 45</p><p class="wf-parking-map__zone-meta">свободно: 18 · занято: 27</p></div>
          <div class="wf-parking-map__zone"><p class="wf-parking-map__zone-title">Долгосрочная ФЛ+ЮЛ — 310</p><p class="wf-parking-map__zone-meta">свободно: 120 · занято: 190</p></div>
          <div class="wf-parking-map__zone"><p class="wf-parking-map__zone-title">Долгосрочная ФЛ+ЮЛ — 15</p><p class="wf-parking-map__zone-meta">свободно: 4 · занято: 11</p></div>
          <div class="wf-parking-map__zone"><p class="wf-parking-map__zone-title">Краткосрочная — 35</p><p class="wf-parking-map__zone-meta">свободно: 10 · занято: 25</p></div>
        </div>
        <div class="wf-parking-map__column">
          <div class="wf-parking-map__zone"><p class="wf-parking-map__zone-title">Краткосрочная — 35</p><p class="wf-parking-map__zone-meta">свободно: 14 · занято: 21</p></div>
          <div class="wf-parking-map__zone"><p class="wf-parking-map__zone-title">Долгосрочная ФЛ+ЮЛ — 15</p><p class="wf-parking-map__zone-meta">свободно: 5 · занято: 10</p></div>
          <div class="wf-parking-map__zone"><p class="wf-parking-map__zone-title">Мун. техника + мото + резерв — 50</p><p class="wf-parking-map__zone-meta">свободно: 20 · занято: 30</p></div>
          <div class="wf-parking-map__zone"><p class="wf-parking-map__zone-title">Краткосрочная — 45</p><p class="wf-parking-map__zone-meta">свободно: 16 · занято: 29</p></div>
          <div class="wf-parking-map__zone"><p class="wf-parking-map__zone-title">ОВЗ — 25</p><p class="wf-parking-map__zone-meta">свободно: 7 · занято: 18</p></div>
        </div>
      </div>
      <div class="wf-parking-map__kpp">КПП юг</div>
      <p class="wf-parking-map__total">Всего 600 мест · свободно: 222 · занято: 378 (загрузка ~63%).</p>
    </div>
  </section>
{% endblock %}
