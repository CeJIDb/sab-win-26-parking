<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}ЛК админа{% endblock %}</title>
  <link rel="stylesheet" href="../wireframe.css">
</head>
<body>
  <a href="#main-content" class="wf-skip-link">Перейти к содержимому</a>
  <div class="wf-page">
    <header class="wf-header wf-header--cabinet" role="banner">
      <div class="wf-header__title">
        <h1>Личный кабинет администратора</h1>
        <p class="wf-muted"><a href="profile.html">Управляющий, Сергеев Сергей Николаевич</a></p>
        <p class="wf-muted wf-header__subtitle">{% block header_subtitle %}{% endblock %}</p>
      </div>
      <a href="notifications.html" class="wf-header__notifications" aria-label="Системные уведомления администратора">
        <span class="wf-header__notifications-icon" aria-hidden="true">🔔</span>
        <span class="wf-header__notifications-text">Сегодня: плановые работы СКУД с 02:00 до 04:00</span>
      </a>
      <button type="button"
              class="wf-burger"
              aria-label="Открыть навигацию"
              aria-controls="admin-nav"
              aria-expanded="false">
        <span class="wf-burger__line" aria-hidden="true"></span>
        <span class="wf-burger__line" aria-hidden="true"></span>
        <span class="wf-burger__line" aria-hidden="true"></span>
      </button>
    </header>
    <div id="admin-nav" class="wf-nav-wrap wf-nav-wrap--admin">
      <div class="wf-nav__breadcrumbs" aria-label="Текущий раздел">
        {% block header_breadcrumbs %}<span class="wf-breadcrumbs__current">Главная</span>{% endblock %}
      </div>
      <div class="wf-nav-level wf-nav-level--main">
        {% set role = "admin" %}
        {% set nav_current = current_nav|default('') %}
        {% include "partials/nav-role.njk" %}
      </div>
      <div class="wf-nav-level wf-nav-level--sub" id="admin-nav-sub" aria-hidden="true">
        <div class="wf-nav-sub-panel" id="admin-nav-sub-parking" data-nav-sub-panel="parking">
          <button type="button" class="wf-nav-sub-back" data-nav-sub-back aria-label="Назад в меню">← Назад</button>
          {% set nav_current = current_nav|default('') %}
          {% include "partials/nav-parking.njk" %}
        </div>
        <div class="wf-nav-sub-panel" id="admin-nav-sub-clients" data-nav-sub-panel="clients">
          <button type="button" class="wf-nav-sub-back" data-nav-sub-back aria-label="Назад в меню">← Назад</button>
          {% set nav_current = current_nav|default('') %}
          {% include "partials/nav-clients.njk" %}
        </div>
        <div class="wf-nav-sub-panel" id="admin-nav-sub-kpp" data-nav-sub-panel="kpp">
          <button type="button" class="wf-nav-sub-back" data-nav-sub-back aria-label="Назад в меню">← Назад</button>
          {% set nav_current = current_nav|default('') %}
          {% include "partials/nav-kpp.njk" %}
        </div>
      </div>
      <div class="wf-nav-level wf-nav-level--aux-desktop">
        {% block auxiliary_nav %}{% endblock %}
      </div>
    </div>
    <main id="main-content" class="wf-main">
      {% block content %}{% endblock %}
    </main>
    <footer class="wf-footer">
      <div class="wf-footer__service">
        <a href="../site/staff-login.html">Выход</a>
      </div>
      <div class="wf-footer__version-toggle" aria-label="Переключение версии интерфейса">
        <span class="wf-footer__version-label">Версия интерфейса:</span>
        <button type="button" class="wf-link-button" data-view-target="desktop" aria-pressed="true">
          для компьютера
        </button>
        <button type="button" class="wf-link-button" data-view-target="mobile" aria-pressed="false">
          для телефона
        </button>
      </div>
    </footer>
  </div>
  <script>
    (function () {
      var body = document.body;
      document.querySelectorAll('.wf-modal__close[href="#main-content"]').forEach(function (closeBtn) {
        closeBtn.addEventListener('click', function (e) {
          if (window.history.length > 1) {
            e.preventDefault();
            window.history.back();
          }
        });
      });

      var viewButtons = document.querySelectorAll('.wf-footer__version-toggle [data-view-target]');
      function applyView(view) {
        if (!body) return;
        body.dataset.view = view;
        try { if (window.localStorage) window.localStorage.setItem('adminView', view); } catch (e) {}
        viewButtons.forEach(function (btn) {
          btn.setAttribute('aria-pressed', btn.getAttribute('data-view-target') === view ? 'true' : 'false');
        });
      }
      if (viewButtons.length) {
        try {
          var stored = window.localStorage && window.localStorage.getItem('adminView');
          if (stored === 'mobile' || stored === 'desktop') applyView(stored);
        } catch (e) {}
        viewButtons.forEach(function (btn) {
          btn.addEventListener('click', function () { applyView(btn.getAttribute('data-view-target') || 'desktop'); });
        });
      }

      var burger = document.querySelector('.wf-burger');
      var adminNav = document.getElementById('admin-nav');
      if (burger && adminNav) {
        function setNavOpen(isOpen) {
          body.dataset.nav = isOpen ? 'open' : 'closed';
          burger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        }
        burger.addEventListener('click', function () { setNavOpen(body.dataset.nav !== 'open'); });
        var breadcrumbsEl = document.querySelector('.wf-nav-wrap--admin .wf-nav__breadcrumbs');
        if (breadcrumbsEl) {
          breadcrumbsEl.addEventListener('click', function () { setNavOpen(true); });
        }
        adminNav.addEventListener('click', function (e) {
          var link = e.target.closest('a');
          if (link && link.hasAttribute('data-nav-sub') && (body.dataset.view === 'mobile' || window.matchMedia('(max-width: 640px)').matches)) {
            e.preventDefault();
            var subId = link.getAttribute('data-nav-sub');
            var subPanel = adminNav.querySelector('[data-nav-sub-panel="' + subId + '"]');
            if (subPanel) {
              adminNav.querySelectorAll('.wf-nav-sub-panel').forEach(function (p) { p.classList.remove('wf-nav-sub-panel--active'); });
              subPanel.classList.add('wf-nav-sub-panel--active');
              adminNav.setAttribute('data-nav-sub-open', subId);
              adminNav.querySelector('.wf-nav-level--sub').setAttribute('aria-hidden', 'false');
            }
            return;
          }
          if (link) {
            if (link.closest('.wf-nav-level--sub')) {
              adminNav.removeAttribute('data-nav-sub-open');
              adminNav.querySelectorAll('.wf-nav-sub-panel').forEach(function (p) { p.classList.remove('wf-nav-sub-panel--active'); });
              adminNav.querySelector('.wf-nav-level--sub').setAttribute('aria-hidden', 'true');
            }
            if (!link.hasAttribute('data-nav-sub')) setNavOpen(false);
          }
        });
        adminNav.querySelectorAll('[data-nav-sub-back]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            adminNav.removeAttribute('data-nav-sub-open');
            adminNav.querySelectorAll('.wf-nav-sub-panel').forEach(function (p) { p.classList.remove('wf-nav-sub-panel--active'); });
            adminNav.querySelector('.wf-nav-level--sub').setAttribute('aria-hidden', 'true');
          });
        });
        if (!body.dataset.nav) setNavOpen(false);
      }

      document.querySelectorAll('.wf-back').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          var href = btn.getAttribute && btn.getAttribute('href');
          if (href && href !== '' && href !== '#') {
            e.preventDefault();
            window.location.href = href;
            return;
          }
          if (window.history.length > 1) {
            window.history.back();
          } else {
            window.location.href = 'index.html';
          }
        });
      });
    })();
  </script>
</body>
</html>
