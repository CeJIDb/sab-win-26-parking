<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Личный кабинет клиента{% endblock %}</title>
  <link rel="stylesheet" href="../wireframe.css">
</head>
<body>
  <a href="#main-content" class="wf-skip-link">Перейти к содержимому</a>
  <div class="wf-page">
    <header class="wf-header wf-header--cabinet" role="banner">
      <div class="wf-header__title">
        <h1>Личный кабинет клиента</h1>
        <p class="wf-muted"><a href="profile.html">Иванов Иван Иванович</a></p>
      </div>
      <a href="notifications.html" class="wf-header__notifications" aria-label="Уведомления клиента">
        <span class="wf-header__notifications-icon" aria-hidden="true">🔔</span>
        <span class="wf-header__notifications-text">Оплата сессии С-1045 на 350 ₽ прошла успешно</span>
      </a>
      <button type="button"
              class="wf-burger"
              aria-label="Открыть навигацию"
              aria-controls="lk-nav"
              aria-expanded="false">
        <span class="wf-burger__line" aria-hidden="true"></span>
        <span class="wf-burger__line" aria-hidden="true"></span>
        <span class="wf-burger__line" aria-hidden="true"></span>
      </button>
    </header>
    {% set nav_current = current_nav|default('') %}
    <nav class="wf-nav wf-nav--cabinet" aria-label="Навигация ЛК клиента" id="lk-nav">
      <div class="wf-nav__breadcrumbs" aria-label="Текущий раздел">
        {% block header_breadcrumbs %}<span class="wf-breadcrumbs__current">Парковка</span>{% endblock %}
      </div>
      {% include "partials/nav-lk.njk" %}
    </nav>
    <main id="main-content" class="wf-main">
      {% block content %}{% endblock %}
    </main>
    <footer class="wf-footer">
      <div class="wf-footer__service">
        <a href="../site/index.html">На сайт парковки</a>
      </div>
      <div class="wf-footer__version-toggle" aria-label="Переключение версии интерфейса">
        <span class="wf-footer__version-label">Версия интерфейса:</span>
        <button type="button" class="wf-link-button" data-view-target="desktop" aria-pressed="true">
          для компьютера
        </button>
        <button type="button" class="wf-link-button" data-view-target="mobile" aria-pressed="false">
          для телефона
        </button>
      </div>
    </footer>
  </div>
  <script>
    (function () {
      var body = document.body;
      if (!body) return;

      // Переключение версии интерфейса (десктоп / мобильная)
      var buttons = document.querySelectorAll('.wf-footer__version-toggle [data-view-target]');

      function applyView(view) {
        body.dataset.view = view;
        try {
          if (window.localStorage) {
            window.localStorage.setItem('lkView', view);
          }
        } catch (e) {}

        buttons.forEach(function (btn) {
          var active = btn.getAttribute('data-view-target') === view;
          btn.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
      }

      if (buttons.length) {
        var stored = null;
        try {
          stored = window.localStorage && window.localStorage.getItem('lkView');
        } catch (e) {}
        if (stored === 'mobile' || stored === 'desktop') {
          applyView(stored);
        }

        buttons.forEach(function (btn) {
          btn.addEventListener('click', function () {
            var view = btn.getAttribute('data-view-target') || 'desktop';
            applyView(view);
          });
        });
      }

      // Бургер-меню для навигации ЛК клиента
      var burger = document.querySelector('.wf-burger');
      var lkNav = document.getElementById('lk-nav');

      function setNavOpen(isOpen) {
        if (!lkNav || !burger) return;
        body.dataset.nav = isOpen ? 'open' : 'closed';
        burger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      }

      function toggleNav() {
        var isOpen = body.dataset.nav === 'open';
        setNavOpen(!isOpen);
      }

      if (burger && lkNav) {
        burger.addEventListener('click', function () {
          toggleNav();
        });

        var breadcrumbsEl = document.querySelector('.wf-nav__breadcrumbs');
        if (breadcrumbsEl) {
          breadcrumbsEl.addEventListener('click', function () { setNavOpen(true); });
        }

        // При загрузке по умолчанию навигация закрыта в мобильном режиме
        if (!body.dataset.nav) {
          setNavOpen(false);
        }

        // Закрывать меню при клике по любому пункту навигации (на мобильных удобно)
        lkNav.addEventListener('click', function (event) {
          if (event.target.tagName === 'A') {
            setNavOpen(false);
          }
        });

        // Открывать меню по клику на хлебные крошки (см. breadcrumbsEl выше)
      }

      // Закрытие модалки: вернуться к предыдущему модальному окну (history.back) или к странице
      document.querySelectorAll('.wf-modal__close[href="#main-content"]').forEach(function (closeBtn) {
        closeBtn.addEventListener('click', function (e) {
          if (window.history.length > 1) {
            e.preventDefault();
            window.history.back();
          }
        });
      });

      // Кнопка «Назад»: при пустой истории — переход на главную (1.2)
      document.querySelectorAll('.wf-back').forEach(function (btn) {
        btn.addEventListener('click', function () {
          if (window.history.length > 1) {
            window.history.back();
          } else {
            window.location.href = 'dashboard.html';
          }
        });
      });
    })();
  </script>
</body>
</html>
