<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Интерфейс КПП — Охранник{% endblock %}</title>
  <link rel="stylesheet" href="../wireframe.css">
</head>
<body>
  <a href="#main-content" class="wf-skip-link">Перейти к содержимому</a>
  <div class="wf-page">
    {% include "partials/guard-header.njk" %}
    {% block header_subtitle %}{% endblock %}
    {% set role = "operator" %}
    {% set nav_current = current_nav|default('') %}
    {% include "partials/nav-role.njk" %}
    <main id="main-content" class="wf-main">
      {% block content %}{% endblock %}
    </main>
  </div>
  <script>
    (function () {
      // Закрытие модалки: вернуться к предыдущей странице или прошлой модалке (history.back)
      document.querySelectorAll('.wf-modal__close[href="#main-content"]').forEach(function (closeBtn) {
        closeBtn.addEventListener('click', function (e) {
          if (window.history.length > 1) {
            e.preventDefault();
            window.history.back();
          }
        });
      });

      // Кнопка «Назад»: при пустой истории — переход на панель КПП
      document.querySelectorAll('.wf-back').forEach(function (btn) {
        btn.addEventListener('click', function () {
          if (window.history.length > 1) {
            window.history.back();
          } else {
            window.location.href = 'index.html';
          }
        });
      });
    })();
  </script>
</body>
</html>

