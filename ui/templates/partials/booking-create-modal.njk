<section id="client-modal-booking-create" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="booking-create-title">
  <div class="wf-modal__dialog wf-section">
    <header class="wf-modal__header">
      <h3 id="booking-create-title">Создать бронирование</h3>
      <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть окно">✕</a>
    </header>
    <form class="wf-form" action="payment-external.html" method="get">
      <div class="wf-field">
        <label for="book-ts">ТС (ГРЗ)</label>
        <select id="book-ts">
          <option value="">— выбрать ТС из добавленных —</option>
          <option value="A123BV777">А123БВ777 — Легковой</option>
          <option value="B456GD199">В456ГД199 — Мотоцикл</option>
        </select>
        <p class="wf-muted">Список ТС можно добавить в <a href="profile.html#profile-vehicles-modal">Профиле</a>. Добавьте ТС, если нужного нет.</p>
      </div>
      <div class="wf-field">
        <label for="book-tariff">Тариф</label>
        <select id="book-tariff">
          <option value="">— выбрать тариф —</option>
          <option value="hourly-a">Почасовой A (краткосрочная)</option>
          <option value="hourly-b">Почасовой B (краткосрочная)</option>
          <option value="hourly-c">Почасовой C (краткосрочная)</option>
          <option value="long">Долгосрочная (свыше 24 ч, требуется договор)</option>
        </select>
        <p id="book-tariff-help" class="wf-muted">
          Выберите тариф: Почасовой A/B/C для краткосрочной парковки или долгосрочный по договору.
        </p>
      </div>
      <div class="wf-field" id="book-date-wrap">
        <label for="book-date">Дата и время начала</label>
        <input id="book-date" type="datetime-local" placeholder="Дата, время">
      </div>
      <div class="wf-field wf-tariff-dependent" id="book-short-wrap" hidden>
        <div class="wf-field">
          <label for="book-sector-short">Сектор (краткосрочная парковка)</label>
          <select id="book-sector-short">
            <option value="">— выбрать сектор —</option>
            <option value="short">Краткосрочная парковка</option>
            <option value="ovz">Места для лиц с ОВЗ</option>
          </select>
        </div>
        <div class="wf-field">
          <label for="book-hours">Время парковки, часы (до 24)</label>
          <input id="book-hours" type="number" min="1" max="24" step="1" placeholder="1–24" aria-label="Количество часов">
        </div>
      </div>
      <div class="wf-field wf-tariff-dependent" id="book-long-wrap" hidden>
        <p class="wf-notice" role="status">
          <strong>Долгосрочная парковка (свыше 24 часов)</strong> оформляется на основании договора обслуживания.
          После заключения договора система автоматически сформирует бронирование на весь срок его действия
          и закрепит за ним ваши парковочные места и транспортные средства.
        </p>
        <div class="wf-actions">
          <a href="contracts-create.html" class="wf-btn">Оформить договор</a>
        </div>
      </div>
      <div id="book-payment-wrap">
        <div class="wf-card">
          <strong>Итого к оплате:</strong> <span class="wf-muted">[сумма по выбранному тарифу и длительности]</span>
        </div>
        <div class="wf-actions">
          <button type="submit">Проверить доступность и перейти к оплате</button>
        </div>
      </div>
    </form>
  </div>
</section>

<script>
(function() {
  var tariff = document.getElementById('book-tariff');
  var shortWrap = document.getElementById('book-short-wrap');
  var longWrap = document.getElementById('book-long-wrap');
  var dateWrap = document.getElementById('book-date-wrap');
  var paymentWrap = document.getElementById('book-payment-wrap');
  var tariffHelp = document.getElementById('book-tariff-help');
  if (!tariff || !shortWrap || !longWrap) return;

  function updateByTariff() {
    var value = tariff.value;
    var isHourly = (value === 'hourly-a' || value === 'hourly-b' || value === 'hourly-c');
    if (tariffHelp) {
      if (value === 'hourly-a') {
        tariffHelp.textContent = 'Почасовой A — дневной 08:00–20:00, от 30 минут, 150 ₽/ч.';
      } else if (value === 'hourly-b') {
        tariffHelp.textContent = 'Почасовой B — ночной 20:00–08:00, от 1 часа, 200 ₽/ч.';
      } else if (value === 'hourly-c') {
        tariffHelp.textContent = 'Почасовой C — круглосуточно, от 15 минут, 250 ₽/ч.';
      } else if (value === 'long') {
        tariffHelp.textContent = 'Долгосрочная парковка — срок от 2 дней, оформляется только по договору обслуживания.';
      } else {
        tariffHelp.textContent = 'Выберите тариф: Почасовой A/B/C для краткосрочной парковки или долгосрочный по договору.';
      }
    }
    if (isHourly) {
      shortWrap.hidden = false;
      longWrap.hidden = true;
      if (dateWrap) dateWrap.hidden = false;
      if (paymentWrap) paymentWrap.hidden = false;
    } else if (value === 'long') {
      shortWrap.hidden = true;
      longWrap.hidden = false;
      if (dateWrap) dateWrap.hidden = true;
      if (paymentWrap) paymentWrap.hidden = true;
    } else {
      shortWrap.hidden = true;
      longWrap.hidden = true;
      if (dateWrap) dateWrap.hidden = false;
      if (paymentWrap) paymentWrap.hidden = false;
    }
  }

  tariff.addEventListener('change', updateByTariff);
})();
</script>

