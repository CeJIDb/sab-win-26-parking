        <form class="wf-form wf-appeal-reply-form">
          <div class="wf-field">
            <label for="appeal-reply-text">Ваше сообщение <span class="wf-required" aria-hidden="true">*</span></label>
            <textarea id="appeal-reply-text" name="reply" rows="3" required placeholder="Введите текст ответа или уточнение" maxlength="2000"></textarea>
          </div>
          <div class="wf-actions">
